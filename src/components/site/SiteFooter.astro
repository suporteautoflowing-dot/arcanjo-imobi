---
interface Props { tenant: any; }
const { tenant } = Astro.props;

const nome     = tenant?.nome_empresa ?? 'Imobiliária';
const whatsapp = tenant?.whatsapp    ?? '';
const email    = tenant?.email       ?? '';
const instagram= tenant?.instagram   ?? '';
const facebook = tenant?.facebook    ?? '';
const endereco = tenant?.endereco    ?? '';
const horario  = tenant?.horario     ?? '';
const creci    = tenant?.creci       ?? '';
const wa       = `https://wa.me/55${whatsapp.replace(/\D/g,'')}`;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand -->
        <div class="footer-brand">
          <div class="footer-logo">
            {tenant?.logo_url ? (
              <img src={tenant.logo_url} alt={nome} class="footer-logo-img" />
            ) : (
              <>
                <div class="footer-logo-icon">
                  <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 2L3 10V26H11V18H17V26H25V10L14 2Z" fill="currentColor"/>
                  </svg>
                </div>
                <div>
                  <span class="footer-logo-brand">{nome.split(' ')[0]}</span>
                  {nome.split(' ').slice(1).join(' ') && (
                    <span class="footer-logo-sub">{nome.split(' ').slice(1).join(' ')}</span>
                  )}
                </div>
              </>
            )}
          </div>
          <p class="footer-tagline">
            Seu parceiro de confiança no mercado imobiliário. {tenant?.cidade ? `Atuando com excelência em ${tenant.cidade}.` : ''}
          </p>
          <div class="footer-social">
            {instagram && (
              <a href={instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link" id="footer-instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
                </svg>
              </a>
            )}
            {facebook && (
              <a href={facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link" id="footer-facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
            )}
            {whatsapp && (
              <a href={wa} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="social-link" id="footer-whatsapp">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </a>
            )}
          </div>
        </div>

        <!-- Links -->
        <div class="footer-col">
          <h4 class="footer-col-title">Imóveis</h4>
          <ul class="footer-links">
            <li><a href="/imoveis?tipo=venda" id="footer-venda">À Venda</a></li>
            <li><a href="/imoveis?tipo=aluguel" id="footer-aluguel">Para Alugar</a></li>
            <li><a href="/imoveis" id="footer-destaque">Todos os Imóveis</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4 class="footer-col-title">Empresa</h4>
          <ul class="footer-links">
            <li><a href="/sobre" id="footer-sobre">Sobre Nós</a></li>
            <li><a href="/#servicos" id="footer-servicos">Serviços</a></li>
            <li><a href="/contato" id="footer-contato-link">Contato</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="footer-col">
          <h4 class="footer-col-title">Contato</h4>
          <ul class="footer-contact">
            {whatsapp && (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9c1.24 2.4 3.12 4.29 5.52 5.52l1.18-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                <span>{whatsapp}</span>
              </li>
            )}
            {email && (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                </svg>
                <span>{email}</span>
              </li>
            )}
            {endereco && (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                <span>{endereco}</span>
              </li>
            )}
            {horario && (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                <span>{horario}</span>
              </li>
            )}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {currentYear} {nome}. Todos os direitos reservados.</p>
      <div style="display:flex; gap: 2rem; align-items:center;">
        {creci && <p>CRECI: {creci}</p>}
        <p class="footer-powered">Powered by <a href="https://wa.me/5585989490455?text=Ol%C3%A1.%20Preciso%20de%20um%20or%C3%A7amento%20para%20desenvolvimento%20de%20um%20projeto%20(Site%2C%20APP%2C%20Sistema)" target="_blank" rel="noopener noreferrer">Vitrine Imob Pro</a></p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    color: rgba(255, 255, 255, 0.75);
  }

  .footer-main {
    padding: var(--space-20) 0 var(--space-16);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.25fr;
    gap: var(--space-12);
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .footer-logo-img {
    height: 48px; width: auto; object-fit: contain;
  }

  .footer-logo-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .footer-logo-brand,
  .footer-logo-sub {
    display: block;
  }

  .footer-logo-brand {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.1;
  }

  .footer-logo-sub {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .footer-tagline {
    font-size: var(--font-size-sm);
    line-height: 1.7;
    margin-bottom: var(--space-6);
    color: rgba(255, 255, 255, 0.6);
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: var(--space-3);
  }

  .social-link {
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.6);
    transition: all var(--transition);
    text-decoration: none;
  }

  .social-link:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white);
    transform: translateY(-2px);
  }

  /* Columns */
  .footer-col-title {
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-white);
    margin-bottom: var(--space-5);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
  }

  .footer-links a {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-links a:hover {
    color: var(--color-white);
  }

  /* Contact */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style: none;
  }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-contact svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-primary);
  }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: var(--space-5) 0;
  }

  .footer-bottom .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-powered a {
    color: var(--color-primary);
    text-decoration: none;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-bottom .container {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
