---
interface Props {
  tenant: any;
  currentPath?: string;
  isHero?: boolean;
}
const { tenant, currentPath = '/', isHero = false } = Astro.props;

const nome = tenant?.nome_empresa ?? 'Imobiliária';
const whatsapp = tenant?.whatsapp ?? '';
const wa = `https://wa.me/55${whatsapp.replace(/\D/g, '')}?text=${encodeURIComponent(`Olá! Gostaria de falar com um especialista da ${nome}.`)}`;

const links = [
  { href: '/',          label: 'Início' },
  { href: '/sobre',     label: 'Sobre' },
  { href: '/imoveis',   label: 'Imóveis' },
  { href: '/#servicos', label: 'Serviços' },
  { href: '/financie',  label: 'Financie' },
  { href: '/negocie',   label: 'Negocie' },
  { href: '/contato',   label: 'Contato' },
];
---

<header class={`site-header ${isHero ? 'site-header--hero' : ''}`} id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo" id="header-logo-link">
      {tenant?.logo_url ? (
        <img src={tenant.logo_url} alt={nome} class="header-logo-img" />
      ) : (
        <div class="header-logo-text">
          <div class="logo-icon" style="background:var(--color-primary);">
            <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 2L3 10V26H11V18H17V26H25V10L14 2Z" fill="white"/>
            </svg>
          </div>
          <div class="logo-wordmark">
            <span class="logo-nome">{nome.split(' ')[0]}</span>
            {nome.split(' ').slice(1).join(' ') && (
              <span class="logo-tipo">{nome.split(' ').slice(1).join(' ')}</span>
            )}
          </div>
        </div>
      )}
    </a>

    <!-- Nav -->
    <nav class="header-nav" id="header-nav">
      {links.map(link => (
        <a href={link.href}
           class={`nav-link ${currentPath === link.href || (link.href !== '/' && !link.href.includes('#') && currentPath.startsWith(link.href)) ? 'active' : ''}`}>
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      {whatsapp && (
        <a href={wa} target="_blank" class="btn-whatsapp" id="header-whatsapp-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span>Fale no WhatsApp</span>
        </a>
      )}
      <button class="menu-toggle" id="menu-toggle" aria-label="Abrir menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- FAB WhatsApp -->
{whatsapp && (
  <a href={wa} target="_blank" class="fab-whatsapp" id="fab-whatsapp" aria-label="WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
)}

<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('header-nav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    toggle.classList.toggle('active');
  });
</script>

<style>
  .site-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: white;
    border-bottom: 1px solid var(--color-border);
    transition: all 0.3s ease;
  }

  .site-header--hero {
    background: transparent;
    border-bottom-color: transparent;
  }

  .site-header.scrolled {
    background: rgba(255, 255, 255, 0.97) !important;
    backdrop-filter: blur(12px);
    border-bottom-color: transparent !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  .header-inner {
    display: flex; align-items: center;
    justify-content: space-between; gap: 2rem;
    height: 76px;
  }

  /* Logo */
  .header-logo { text-decoration: none; flex-shrink: 0; }
  .header-logo-img { height: 48px; width: auto; object-fit: contain; }
  .header-logo-text { display: flex; align-items: center; gap: 0.75rem; }

  .logo-icon {
    width: 44px; height: 44px; border-radius: var(--radius);
    background: var(--color-primary);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .logo-wordmark { display: flex; flex-direction: row; align-items: center; gap: 0.35rem; line-height: 1.1; }
  .logo-nome { font-size: 1.25rem; font-weight: 800; color: var(--color-text); letter-spacing: -0.02em; transition: color 0.3s ease; }
  .logo-tipo { font-size: 1.25rem; font-weight: 800; color: var(--color-primary); letter-spacing: -0.02em; transition: color 0.3s ease; }

  /* Nav */
  .header-nav { display: flex; align-items: center; gap: 0.25rem; flex: 1; justify-content: center; }

  .nav-link {
    padding: 0.5rem 1rem; font-size: 0.9rem; font-weight: 600;
    color: var(--color-muted); text-decoration: none;
    border-radius: var(--radius); transition: all var(--transition);
    white-space: nowrap;
  }

  .nav-link:hover { color: var(--color-text); }
  .nav-link.active { color: var(--color-primary); background: var(--color-primary-light); }

  /* Actions */
  .header-actions { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }

  .btn-whatsapp {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: transparent; color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.9rem; font-weight: 600;
    text-decoration: none; transition: all var(--transition);
    white-space: nowrap;
  }

  .btn-whatsapp:hover { 
    color: var(--color-primary); 
    border-color: var(--color-primary); 
    background: var(--color-primary-light); 
    transform: translateY(-1px); 
  }

  /* --- HERO OVERRIDES (Quando no topo da home) --- */
  .site-header--hero:not(.scrolled) .logo-nome { color: white; }
  .site-header--hero:not(.scrolled) .logo-tipo { color: #93c5fd; }
  .site-header--hero:not(.scrolled) .nav-link { color: rgba(255,255,255,0.88); }
  
  .site-header--hero:not(.scrolled) .nav-link:hover,
  .site-header--hero:not(.scrolled) .nav-link.active { 
    color: white; 
    background: rgba(255,255,255,0.15); 
  }
  
  .site-header--hero:not(.scrolled) .btn-whatsapp {
    color: rgba(255,255,255,0.88);
    border-color: rgba(255,255,255,0.4);
  }
  
  .site-header--hero:not(.scrolled) .btn-whatsapp:hover {
    color: white;
    border-color: white;
    background: rgba(255,255,255,0.15);
  }
  
  .site-header--hero:not(.scrolled) .menu-toggle span { background: white; }

  /* FAB */
  .fab-whatsapp {
    position: fixed; bottom: 1.75rem; right: 1.75rem; z-index: 200;
    width: 56px; height: 56px; border-radius: 50%;
    background: #25D366; color: white;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.5);
    transition: all 0.25s ease;
  }

  .fab-whatsapp:hover { background: #128C7E; transform: scale(1.1); }

  /* Menu toggle mobile */
  .menu-toggle {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 4px;
  }

  .menu-toggle span {
    display: block; width: 22px; height: 2px;
    background: var(--color-text); transition: all 0.3s;
  }

  @media (max-width: 900px) {
    .menu-toggle { display: flex; }

    .header-nav {
      display: none; position: absolute;
      top: 76px; left: 0; right: 0;
      background: white; border-bottom: 1px solid var(--color-border);
      flex-direction: column; padding: 0.75rem;
      gap: 0.125rem; box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }

    .header-nav.open { display: flex; }
    .nav-link { width: 100%; }
    .btn-whatsapp span { display: none; }
    .btn-whatsapp { padding: 0.5rem; }
  }
</style>
