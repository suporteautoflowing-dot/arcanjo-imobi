---
interface Props { title: string; breadcrumb?: string; tenant: any; }
const { title, breadcrumb, tenant } = Astro.props;

const initial = tenant?.nome_empresa ? tenant.nome_empresa.charAt(0).toUpperCase() : 'C';
---
<header class="topbar">
  <div>
    <div class="topbar-title">{title}</div>
    {breadcrumb && <div class="topbar-breadcrumb">{breadcrumb}</div>}
  </div>
  <div class="topbar-right">
    <div class="topbar-avatar">{initial}</div>
    <form method="GET" action="/auth/logout">
      <button type="submit" class="btn-logout">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Sair
      </button>
    </form>
  </div>
</header>
