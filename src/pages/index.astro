---
/**
 * Página inicial do SITE PÚBLICO de cada imobiliária
 * Rota: / (quando acessada via subdomínio ou domínio custom do tenant)
 * O tenant é resolvido pelo middleware e fica em Astro.locals.tenant
 */
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import PropertyCard from '../components/site/PropertyCard.astro';
import { db } from '../lib/db';
import { imoveis, leads } from '../lib/schema';
import { eq, and, desc } from 'drizzle-orm';

const tenant = (Astro.locals as any).tenant;

// Se não há tenant, é a landing page da plataforma
// Redirecionar para a landing page existente ou mostrar uma mensagem padrão
if (!tenant) {
  return Astro.rewrite('/landing-platform');
}

// Imóveis em destaque do tenant
const imoveisData = await db.select().from(imoveis)
  .where(and(eq(imoveis.tenant_id, tenant.id), eq(imoveis.status, 'disponivel')))
  .orderBy(desc(imoveis.created_at));

const destaques = imoveisData.filter(i => i.destaque).slice(0, 6);
const recentes  = destaques.length === 0 ? imoveisData.slice(0, 6) : destaques;

const hero = {
  titulo:      tenant.hero_titulo      ?? 'Encontre o imóvel dos seus sonhos',
  subtitulo:   (tenant.sobre_json as any)?.hero_subtitulo ?? 'Imóveis selecionados com qualidade e segurança.',
  cta_venda:   tenant.hero_cta_venda   ?? 'Ver imóveis à venda',
  cta_aluguel: tenant.hero_cta_aluguel ?? 'Para alugar',
  stat_imoveis:   tenant.stat_imoveis   ?? `${imoveisData.length}+`,
  stat_anos:      tenant.stat_anos      ?? '5+',
  stat_clientes:  tenant.stat_clientes  ?? '100+',
  imagem:      tenant.hero_imagem      ?? '/images/hero-bg.jpg',
};

// Processar lead capture
let leadSent = false;
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const nome = form.get('nome')?.toString();
  const whatsapp = form.get('whatsapp')?.toString();
  if (nome && whatsapp) {
    await db.insert(leads).values({
      tenant_id: tenant.id,
      nome,
      whatsapp,
      origem: 'contato',
      status: 'novo',
    });
    leadSent = true;
  }
}
---

<SiteLayout title={`${tenant.nome_empresa} — Imóveis`} tenant={tenant}>
  <SiteHeader tenant={tenant} currentPath="/" isHero={true} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-overlay"></div>
    {hero.imagem && <div class="hero-image-bg" style={`background-image:url('${hero.imagem}')`}></div>}
    <div class="container hero-content">
      <span class="section-label" style="color:#93c5fd;">{tenant.nome_empresa?.toUpperCase()}</span>
      <h1 class="hero-title">
        {(() => {
          const words = hero.titulo.split(' ');
          if (words.length <= 1) return hero.titulo;
          const last = words.at(-1)!;
          const rest = words.slice(0, -1).join(' ');
          return <>{rest}<br /><span>{last}</span></>;
        })()}
      </h1>
      <p class="hero-desc">{hero.subtitulo}</p>
      <div class="hero-actions">
        <a href="/imoveis?tipo=venda" class="btn btn-primary btn-lg" id="hero-cta-comprar">{hero.cta_venda}</a>
        <a href="/imoveis?tipo=aluguel" class="btn btn-outline btn-lg" id="hero-cta-alugar">{hero.cta_aluguel}</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><strong>{hero.stat_imoveis}</strong><span>Imóveis</span></div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>{hero.stat_anos}</strong><span>Anos de mercado</span></div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>{hero.stat_clientes}</strong><span>Clientes atendidos</span></div>
      </div>
    </div>
  </section>

  <!-- BUSCA RÁPIDA -->
  <section class="search-section">
    <div class="container">
      <div class="search-card fade-in">
        <div class="search-tabs">
          <button type="button" class="search-tab active" data-tipo="" id="tab-todos">Todos</button>
          <button type="button" class="search-tab" data-tipo="venda" id="tab-comprar">Comprar</button>
          <button type="button" class="search-tab" data-tipo="aluguel" id="tab-alugar">Alugar</button>
        </div>
        <form action="/imoveis" method="get" class="search-form">
          <input type="hidden" name="tipo" id="search-tipo" value="" />
          <div class="search-field">
            <div class="search-field-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="search-field-body">
              <label for="busca-bairro" class="search-label">Localização</label>
              <input type="text" name="bairro" id="busca-bairro" class="search-input" placeholder="Bairro ou cidade..." />
            </div>
          </div>
          <div class="search-sep"></div>
          <div class="search-field">
            <div class="search-field-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div class="search-field-body">
              <label for="preco-max" class="search-label">Preço máximo</label>
              <select name="preco_max" id="preco-max" class="search-input search-select">
                <option value="">Qualquer preço</option>
                <option value="300000">Até R$ 300.000</option>
                <option value="500000">Até R$ 500.000</option>
                <option value="1000000">Até R$ 1.000.000</option>
                <option value="2000000">Até R$ 2.000.000</option>
              </select>
            </div>
          </div>
          <button type="submit" class="search-submit" id="search-submit-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <span>Buscar</span>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- DESTAQUES -->
  <section class="section" id="destaques">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">IMÓVEIS {destaques.length > 0 ? 'EM DESTAQUE' : 'RECENTES'}</span>
        <h2 class="section-title">As melhores <span>oportunidades</span></h2>
        <p class="section-desc">Selecionamos os imóveis mais especiais para você. Qualidade e localização privilegiada.</p>
      </div>

      {recentes.length > 0 ? (
        <div class="grid-3 properties-grid">
          {recentes.map((imovel, i) => (
            <div class="fade-in" style={`transition-delay:${i * 0.08}s`}>
              <PropertyCard imovel={imovel} />
            </div>
          ))}
        </div>
      ) : (
        <div style="text-align:center;padding:3rem;color:var(--color-muted);">
          <p>Nenhum imóvel disponível no momento.</p>
          <p style="font-size:0.875rem;margin-top:0.5rem;">Em breve novidades!</p>
        </div>
      )}

      <div class="section-cta fade-in">
        <a href="/imoveis" class="btn btn-outline-dark btn-lg" id="ver-todos-btn">Ver todos os imóveis</a>
      </div>
    </div>
  </section>

  <!-- SERVIÇOS -->
  <section class="section section-alt" id="servicos">
    <div class="container">
      <div class="section-header fade-in" style="text-align:center;align-items:center;">
        <span class="section-label">NOSSOS SERVIÇOS</span>
        <h2 class="section-title">Como podemos <span>te ajudar</span></h2>
      </div>
      <div class="services-grid">
        {[
          { icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>', titulo: 'Compra de Imóveis', desc: 'Encontramos o imóvel ideal para você com assessoria completa do início ao fim da negociação.' },
          { icon: '<path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>', titulo: 'Venda de Imóveis', desc: 'Avaliação gratuita, divulgação ampla e acompanhamento profissional para vender mais rápido.' },
          { icon: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>', titulo: 'Aluguel e Gestão', desc: 'Administração completa de imóveis para locação com segurança jurídica e financeira.' },
          { icon: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>', titulo: 'Consultoria', desc: 'Análise de mercado, orientação de investimentos e consultoria personalizada.' },
        ].map((s, i) => (
          <div class="service-card fade-in" style={`transition-delay:${i * 0.1}s`}>
            <div class="service-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
            </div>
            <h3 class="service-title">{s.titulo}</h3>
            <p class="service-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIAL -->
  <section class="section diferencial">
    <div class="container">
      <div class="diferencial-inner">
        <div class="diferencial-content fade-in">
          <span class="section-label" style="color:#93c5fd;">NOSSO DIFERENCIAL</span>
          <h2 class="section-title" style="color:white;">Por que escolher a <span style="color:#93c5fd;">{tenant.nome_empresa}?</span></h2>
          <ul class="diferencial-list">
            {[
              'Equipe especializada com anos de experiência no mercado',
              'Processo transparente e seguro em todas as etapas',
              'Atendimento personalizado para cada cliente',
              'Portfólio exclusivo de imóveis selecionados',
            ].map(item => (
              <li>
                <div class="check-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contato" class="btn btn-primary btn-lg" id="diferencial-cta">Fale com um especialista</a>
        </div>
        <div class="diferencial-image fade-in">
          <div class="diferencial-placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.2;color:white;">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div class="diferencial-badge">
            <strong>{hero.stat_clientes}</strong>
            <span>famílias atendidas</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LEAD CAPTURE -->
  <section class="section section-alt" id="anunciar">
    <div class="container">
      {leadSent ? (
        <div class="lead-banner fade-in" style="justify-content:center;text-align:center;">
          <div>
            <div style="font-size:3rem;margin-bottom:1rem;">✅</div>
            <h3>Recebemos seu contato!</h3>
            <p>Nossa equipe entrará em contato pelo WhatsApp em breve.</p>
          </div>
        </div>
      ) : (
        <div class="lead-banner fade-in">
          <div class="lead-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <div class="lead-text">
            <h3>Quer anunciar seu imóvel?</h3>
            <p>Deixe seus dados e nossa equipe entrará em contato rapidamente.</p>
          </div>
          <form class="lead-form" method="POST">
            <input type="text" name="nome" placeholder="Seu nome" class="form-input" required />
            <input type="tel" name="whatsapp" placeholder="Seu WhatsApp" class="form-input" required />
            <button type="submit" class="btn btn-primary" id="lead-submit-btn">Quero anunciar</button>
          </form>
        </div>
      )}
    </div>
  </section>

  <SiteFooter tenant={tenant} />
</SiteLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.search-tab');
  const tipoInput = document.getElementById('search-tipo') as HTMLInputElement;
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      tipoInput.value = tab.dataset.tipo ?? '';
    });
  });
</script>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-dark);
  }

  .hero-image-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.35;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(15,23,42,0.92) 0%, rgba(15,23,42,0.6) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 6rem;
    padding-bottom: 8rem;
    max-width: 700px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: white;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero-title span { color: var(--color-primary); }
  .hero-desc { font-size: 1.125rem; color: rgba(255,255,255,0.75); margin-bottom: 2rem; max-width: 540px; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }

  .hero-stats { display: flex; align-items: center; gap: 2rem; }
  .stat { display: flex; flex-direction: column; }
  .stat strong { font-size: 1.5rem; font-weight: 800; color: white; }
  .stat span { font-size: 0.8rem; color: rgba(255,255,255,0.6); }
  .stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.15); }

  /* SEARCH */
  .search-section { margin-top: -3rem; position: relative; z-index: 10; }
  .search-card { background: white; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 4px 12px rgba(0,0,0,0.08); overflow: hidden; }
  .search-tabs { display: flex; background: var(--color-bg-alt); border-bottom: 1px solid var(--color-border); padding: 0 1.5rem; }
  .search-tab { padding: 0.875rem 1.25rem; font-size: 0.875rem; font-weight: 600; color: var(--color-muted); background: none; border: none; border-bottom: 2.5px solid transparent; cursor: pointer; transition: all 0.2s; margin-bottom: -1px; }
  .search-tab:hover { color: var(--color-text); }
  .search-tab.active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .search-form { display: flex; align-items: center; padding: 1.25rem 1.5rem; }
  .search-field { flex: 1; display: flex; align-items: center; gap: 0.875rem; padding: 0.5rem 1rem; border-radius: var(--radius-lg); transition: background 0.2s; }
  .search-field:hover { background: var(--color-bg-alt); }
  .search-field-icon { color: var(--color-primary); flex-shrink: 0; opacity: 0.8; }
  .search-field-body { display: flex; flex-direction: column; gap: 0.2rem; flex: 1; min-width: 0; }
  .search-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); }
  .search-input { border: none; background: transparent; font-size: 0.95rem; font-weight: 500; color: var(--color-text); padding: 0; outline: none; width: 100%; }
  .search-select { appearance: none; cursor: pointer; }
  .search-sep { width: 1px; height: 36px; background: var(--color-border); flex-shrink: 0; margin: 0 0.25rem; }
  .search-submit { flex-shrink: 0; display: flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; background: var(--color-primary); color: white; border: none; border-radius: var(--radius-lg); font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: all 0.2s; margin-left: 0.75rem; box-shadow: 0 4px 14px color-mix(in srgb, var(--color-primary) 35%, transparent); }
  .search-submit:hover { background: var(--color-primary-dark); transform: translateY(-1px); }

  /* PROPERTIES */
  .section-header { display: flex; flex-direction: column; margin-bottom: 3rem; }
  .properties-grid { margin-bottom: 2.5rem; }
  .section-cta { text-align: center; }

  /* SERVICES */
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .service-card { padding: 2rem 1.5rem; text-align: center; transition: transform 0.25s; }
  .service-card:hover { transform: translateY(-4px); }
  .service-icon { width: 72px; height: 72px; border-radius: var(--radius-xl); background: var(--color-primary-light); color: var(--color-primary); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; }
  .service-title { font-size: 1.05rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem; }
  .service-desc { font-size: 0.875rem; color: var(--color-muted); line-height: 1.7; }

  /* DIFERENCIAL */
  .diferencial { background: var(--color-dark); }
  .diferencial-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .diferencial-content .section-title { margin-bottom: 1.5rem; }
  .diferencial-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
  .diferencial-list li { display: flex; align-items: flex-start; gap: 0.75rem; font-size: var(--font-size-base); color: rgba(255,255,255,0.8); }
  .check-icon { width: 24px; height: 24px; border-radius: 50%; background: var(--color-primary); color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
  .diferencial-image { position: relative; border-radius: var(--radius-xl); overflow: hidden; aspect-ratio: 4/3; background: rgba(255,255,255,0.05); }
  .diferencial-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  .diferencial-badge { position: absolute; bottom: 1.5rem; left: 1.5rem; background: var(--color-primary); color: white; border-radius: var(--radius-lg); padding: 1rem 1.25rem; display: flex; flex-direction: column; line-height: 1.2; }
  .diferencial-badge strong { font-size: 1.5rem; font-weight: 800; }
  .diferencial-badge span { font-size: 0.75rem; opacity: 0.9; }

  /* LEAD */
  .lead-banner { background: white; border-radius: var(--radius-xl); box-shadow: var(--shadow-md); padding: 2rem 2.5rem; display: flex; align-items: center; gap: 2rem; }
  .lead-icon { width: 72px; height: 72px; border-radius: var(--radius-xl); background: var(--color-primary-light); color: var(--color-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .lead-text { flex: 1; }
  .lead-text h3 { font-size: 1.25rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.25rem; }
  .lead-text p { font-size: 0.875rem; color: var(--color-muted); }
  .lead-form { display: flex; gap: 0.75rem; flex-shrink: 0; }
  .lead-form .form-input { width: 180px; }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .diferencial-inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .search-form { flex-direction: column; align-items: stretch; padding: 1rem; }
    .search-sep { display: none; }
    .search-submit { margin: 0.75rem 0 0; width: 100%; justify-content: center; padding: 1rem; border-radius: var(--radius-lg); }
    .lead-banner { flex-direction: column; text-align: center; padding: 1.5rem; }
    .lead-form { flex-direction: column; width: 100%; }
    .lead-form .form-input { width: 100%; }
    .hero-stats { gap: 1rem; }
  }
  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
  }
</style>
