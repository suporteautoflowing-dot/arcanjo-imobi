---
import SiteLayout from '../../layouts/SiteLayout.astro';
import SiteHeader from '../../components/site/SiteHeader.astro';
import SiteFooter from '../../components/site/SiteFooter.astro';
import { db } from '../../lib/db';
import { imoveis, leads } from '../../lib/schema';
import { eq, and } from 'drizzle-orm';

const tenant = (Astro.locals as any).tenant;
if (!tenant) return Astro.redirect('/');

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/imoveis');

const [im] = await db.select().from(imoveis)
  .where(and(eq(imoveis.slug, slug), eq(imoveis.tenant_id, tenant.id)))
  .limit(1);
if (!im) return Astro.redirect('/imoveis');

let leadSent = false;
if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  if (f.get('nome')) {
    await db.insert(leads).values({
      tenant_id: tenant.id,
      nome: f.get('nome')!.toString(),
      whatsapp: f.get('whatsapp')?.toString(),
      email: f.get('email')?.toString(),
      mensagem: f.get('mensagem')?.toString(),
      imovel_id: im.id,
      origem: 'imovel',
      status: 'novo',
    });
    leadSent = true;
  }
}

const fmt = (v: any) => Number(v).toLocaleString('pt-BR', { style:'currency', currency:'BRL', maximumFractionDigits:0 });
const galeria: string[] = Array.isArray(im.galeria) ? im.galeria : [];
const fotos = [im.capa, ...galeria].filter(Boolean) as string[];
const whatsappMsg = encodeURIComponent(`Olá! Tenho interesse no imóvel: ${im.titulo} (Cód: ${im.id}). Gostaria de mais informações.`);
const wa = `https://wa.me/55${(tenant.whatsapp??'').replace(/\D/g,'')}?text=${whatsappMsg}`;
const fotosJson = JSON.stringify(fotos);

// Formatamos a descrição para HTML substituindo quebras de linha por <br>
const descHTML = im.descricao ? im.descricao.replace(/\n/g, '<br>') : '';
---

<SiteLayout title={`${im.titulo} — ${tenant.nome_empresa}`} description={im.descricao ?? undefined} tenant={tenant}>
  <SiteHeader tenant={tenant} currentPath="/imoveis" />

  <main class="property-page">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Navegação">
        <a href="/">Início</a>
        <span>›</span>
        <a href="/imoveis">Imóveis</a>
        <span>›</span>
        <span>{im.titulo}</span>
      </nav>

      <div class="property-layout">
        <!-- COLUNA PRINCIPAL -->
        <div class="property-main">
          <!-- Galeria com Lightbox -->
          <div class="gallery" id="gallery">
            <!-- Imagem principal com setas -->
            <div class="gallery-main">
              {fotos.length > 0 ? (
                <img src={fotos[0]} alt={im.titulo} class="main-image" id="main-gallery-img" />
              ) : (
                <div class="gallery-empty">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
              )}
              <span class={`badge ${im.tipo === 'venda' ? 'badge-venda' : 'badge-aluguel'} gallery-badge`}>
                {im.tipo === 'venda' ? 'À VENDA' : 'PARA ALUGAR'}
              </span>
              <!-- Contador -->
              {fotos.length > 1 && (
                <>
                  <div class="gallery-counter" id="gallery-counter">
                    1 / {fotos.length}
                  </div>
                  <!-- Setas de navegação -->
                  <button class="gallery-nav gallery-nav-prev" id="gallery-prev" aria-label="Foto anterior">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                  </button>
                  <button class="gallery-nav gallery-nav-next" id="gallery-next" aria-label="Próxima foto">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                  </button>
                  <!-- Botão ver todas -->
                  <button class="gallery-all-btn" id="gallery-open-btn" aria-label="Ver todas as fotos">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    Ver todas as {fotos.length} fotos
                  </button>
                </>
              )}
            </div>

            <!-- Miniaturas (máx 8 fotos) -->
            {fotos.length > 1 && (
              <div class="gallery-grid">
                {fotos.slice(0, 8).map((img, i) => (
                  <button
                    class={`gallery-thumb ${i === 0 ? 'active' : ''}`}
                    data-index={i}
                    data-src={img}
                    aria-label={`Ver foto ${i + 1}`}
                  >
                    <img src={img} alt={`Foto ${i + 1}`} loading="lazy" onerror="this.src='/images/placeholder.jpg'" />
                    {i === 7 && fotos.length > 8 && (
                      <div class="thumb-more">+{fotos.length - 8}</div>
                    )}
                  </button>
                ))}
              </div>
            )}
          </div>

          <!-- Lightbox Modal -->
          <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Galeria de fotos">
            <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
            <div class="lightbox-content">
              <div class="lightbox-header">
                <span class="lightbox-counter" id="lightbox-counter">1 / {fotos.length}</span>
                <button class="lightbox-close" id="lightbox-close" aria-label="Fechar galeria">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
              <div class="lightbox-img-wrap">
                <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Foto anterior">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <img src={fotos[0]} alt={im.titulo} class="lightbox-img" id="lightbox-img" onerror="this.src='/images/placeholder.jpg'" />
                <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Próxima foto">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>
              <!-- Tira de miniaturas no lightbox -->
              <div class="lightbox-thumbs" id="lightbox-thumbs">
                {fotos.map((img, i) => (
                  <button class={`lightbox-thumb-btn ${i === 0 ? 'active' : ''}`} data-index={i} data-src={img} aria-label={`Foto ${i + 1}`}>
                    <img src={img} alt={`Miniatura ${i + 1}`} loading="lazy" onerror="this.src='/images/placeholder.jpg'" />
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- Título e preço mobile -->
          <div class="property-header-mobile">
            <h1 class="property-title">{im.titulo}</h1>
            <p class="property-price">{fmt(im.preco)}{im.tipo === 'aluguel' ? '/mês' : ''}</p>
          </div>

          <!-- Features -->
          <div class="features-bar">
            {(im.quartos ?? 0) > 0 && (
              <div class="feature-item">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v15"/><path d="M3 18h18"/><path d="M3 14h18"/><path d="M7 22v-4"/><path d="M17 22v-4"/></svg>
                <div><strong>{im.quartos}</strong><span>{im.quartos === 1 ? 'Quarto' : 'Quartos'}</span></div>
              </div>
            )}
            {(im.banheiros ?? 0) > 0 && (
              <div class="feature-item">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h16"/><path d="M4 12a8 8 0 0 1 16 0"/><path d="M2 20h20"/></svg>
                <div><strong>{im.banheiros}</strong><span>{im.banheiros === 1 ? 'Banheiro' : 'Banheiros'}</span></div>
              </div>
            )}
            {(im.area ?? 0) > 0 && (
              <div class="feature-item">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M3 9h18"/></svg>
                <div><strong>{im.area}m²</strong><span>Área</span></div>
              </div>
            )}
            {(im.vagas ?? 0) > 0 && (
              <div class="feature-item">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <div><strong>{im.vagas}</strong><span>{im.vagas === 1 ? 'Vaga' : 'Vagas'}</span></div>
              </div>
            )}
          </div>

          <!-- Descrição -->
          {im.descricao && (
            <div class="property-description">
              <h2>Sobre o imóvel</h2>
              <div class="property-content" set:html={descHTML} />
            </div>
          )}
        </div>

        <!-- SIDEBAR -->
        <aside class="property-sidebar">
          <div class="sidebar-card">
            <h1 class="sidebar-title">{im.titulo}</h1>
            {(im.bairro || im.cidade) && (
              <p class="sidebar-location">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {[im.bairro, im.cidade, im.estado].filter(Boolean).join(', ')}
              </p>
            )}
            <p class="sidebar-price">{fmt(im.preco)}{im.tipo === 'aluguel' ? '/mês' : ''}</p>
            <p class="sidebar-code">Cód: {im.id}</p>

            <div class="sidebar-actions">
              {tenant.whatsapp && (
                <a
                  href={wa}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-primary"
                  style="width:100%; justify-content:center;"
                  id="property-whatsapp-btn"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  Falar pelo WhatsApp
                </a>
              )}
              <a href="/contato" class="btn btn-outline-dark" style="width:100%; justify-content:center;" id="property-contact-btn">
                Solicitar visita
              </a>
            </div>

            <div class="sidebar-info">
              <div class="info-row">
                <span>Tipo</span>
                <strong>{im.tipo === 'venda' ? 'Venda' : 'Aluguel'}</strong>
              </div>
              {(im.area ?? 0) > 0 && (
                <div class="info-row">
                  <span>Área</span>
                  <strong>{im.area} m²</strong>
                </div>
              )}
              {(im.quartos ?? 0) > 0 && <div class="info-row"><span>Quartos</span><strong>{im.quartos}</strong></div>}
              {(im.banheiros ?? 0) > 0 && <div class="info-row"><span>Banheiros</span><strong>{im.banheiros}</strong></div>}
              {(im.vagas ?? 0) > 0 && <div class="info-row"><span>Vagas</span><strong>{im.vagas}</strong></div>}
              {im.categoria && <div class="info-row"><span>Categoria</span><strong>{im.categoria}</strong></div>}
              <div class="info-row">
                <span>Status</span>
                <strong>{im.status}</strong>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <SiteFooter tenant={tenant} />
</SiteLayout>

<script define:vars={{ fotosJson }}>
  const fotos = JSON.parse(fotosJson);
  if (!fotos.length) return;

  let currentIdx = 0;

  // Elementos
  const mainImg     = document.getElementById('main-gallery-img');
  const counter     = document.getElementById('gallery-counter');
  const thumbs      = document.querySelectorAll('.gallery-thumb');
  const prevBtn     = document.getElementById('gallery-prev');
  const nextBtn     = document.getElementById('gallery-next');
  const openBtn     = document.getElementById('gallery-open-btn');
  const lightbox    = document.getElementById('lightbox');
  const lbImg       = document.getElementById('lightbox-img');
  const lbCounter   = document.getElementById('lightbox-counter');
  const lbClose     = document.getElementById('lightbox-close');
  const lbBackdrop  = document.getElementById('lightbox-backdrop');
  const lbPrev      = document.getElementById('lightbox-prev');
  const lbNext      = document.getElementById('lightbox-next');
  const lbThumbs    = document.querySelectorAll('.lightbox-thumb-btn');

  function goTo(idx) {
    currentIdx = (idx + fotos.length) % fotos.length;
    const src = fotos[currentIdx];

    if (mainImg) mainImg.src = src;
    if (counter) counter.textContent = `${currentIdx + 1} / ${fotos.length}`;
    thumbs.forEach((t, i) => t.classList.toggle('active', i === currentIdx));

    if (lbImg) lbImg.src = src;
    if (lbCounter) lbCounter.textContent = `${currentIdx + 1} / ${fotos.length}`;
    lbThumbs.forEach((t, i) => t.classList.toggle('active', i === currentIdx));

    const activeLbThumb = lbThumbs[currentIdx];
    activeLbThumb?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  thumbs.forEach(btn => btn.addEventListener('click', () => goTo(Number(btn.dataset.index))));
  prevBtn?.addEventListener('click', () => goTo(currentIdx - 1));
  nextBtn?.addEventListener('click', () => goTo(currentIdx + 1));

  function openLightbox(idx) {
    goTo(idx);
    lightbox?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.remove('open');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', () => openLightbox(currentIdx));
  if (mainImg) {
    mainImg.style.cursor = 'zoom-in';
    mainImg.addEventListener('click', () => openLightbox(currentIdx));
  }

  lbClose?.addEventListener('click', closeLightbox);
  lbBackdrop?.addEventListener('click', closeLightbox);
  lbPrev?.addEventListener('click', () => goTo(currentIdx - 1));
  lbNext?.addEventListener('click', () => goTo(currentIdx + 1));

  lbThumbs.forEach(btn => btn.addEventListener('click', () => goTo(Number(btn.dataset.index))));

  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('open')) return;
    if (e.key === 'ArrowLeft')  goTo(currentIdx - 1);
    if (e.key === 'ArrowRight') goTo(currentIdx + 1);
    if (e.key === 'Escape')     closeLightbox();
  });
</script>

<style>
  .property-page {
    padding-top: 80px;
    padding-bottom: var(--space-20);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    padding: var(--space-5) 0;
  }

  .breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .breadcrumb a:hover { text-decoration: underline; }

  .property-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--space-10);
    align-items: start;
  }

  /* ── Gallery ────────────────────────── */
  .gallery { margin-bottom: var(--space-6); }

  .gallery-main {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16/9;
    background: var(--color-dark);
    cursor: pointer;
  }

  .gallery-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.2);
  }

  .main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery-main:hover .main-image { transform: scale(1.02); }

  .badge {
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .badge-venda { background: var(--color-primary); color: white; }
  .badge-aluguel { background: #16a34a; color: white; }

  .gallery-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
  }

  .gallery-counter {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background: rgba(0,0,0,0.6);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
    backdrop-filter: blur(4px);
    z-index: 2;
  }

  /* Setas de navegação na imagem principal */
  .gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(4px);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: all var(--transition);
    z-index: 2;
    box-shadow: var(--shadow-sm);
  }

  .gallery-nav:hover {
    background: var(--color-white);
    box-shadow: var(--shadow);
    transform: translateY(-50%) scale(1.08);
  }

  .gallery-nav-prev { left: 0.75rem; }
  .gallery-nav-next { right: 0.75rem; }

  /* Botão ver todas */
  .gallery-all-btn {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(4px);
    border: none;
    border-radius: var(--radius);
    padding: 0.4rem 0.875rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: all var(--transition);
    z-index: 2;
  }

  .gallery-all-btn:hover {
    background: var(--color-white);
    box-shadow: var(--shadow);
  }

  /* Grid de miniaturas (até 8) */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .gallery-thumb {
    position: relative;
    aspect-ratio: 1;
    border-radius: var(--radius);
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all var(--transition);
    background: none;
    padding: 0;
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s;
  }

  .gallery-thumb:hover img { transform: scale(1.08); }
  .gallery-thumb.active { border-color: var(--color-primary); }
  .gallery-thumb.active img { opacity: 0.9; }

  .thumb-more {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
  }

  /* ── Lightbox ────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .lightbox.open { display: flex; }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.92);
    backdrop-filter: blur(8px);
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1100px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    max-height: 100vh;
  }

  .lightbox-header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .lightbox-counter {
    color: rgba(255,255,255,0.7);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .lightbox-close {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.12);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition);
  }

  .lightbox-close:hover { background: rgba(255,255,255,0.22); }

  .lightbox-img-wrap {
