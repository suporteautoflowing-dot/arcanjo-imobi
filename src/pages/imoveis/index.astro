---
/**
 * Listagem de imóveis do site público do tenant
 * Layout fiel ao original Arcanjo Imóveis:
 * - Header branco com contagem
 * - Sidebar de filtros à esquerda (sticky)
 * - Grid 2 colunas à direita
 */
import SiteLayout from '../../layouts/SiteLayout.astro';
import SiteHeader from '../../components/site/SiteHeader.astro';
import SiteFooter from '../../components/site/SiteFooter.astro';
import PropertyCard from '../../components/site/PropertyCard.astro';
import { db } from '../../lib/db';
import { imoveis } from '../../lib/schema';
import { eq } from 'drizzle-orm';

const tenant = (Astro.locals as any).tenant;
if (!tenant) return Astro.redirect('/');

const params      = Astro.url.searchParams;
const filtroTipo   = params.get('tipo')      ?? '';
const filtroBairro = params.get('bairro')    ?? '';
const filtroPreco  = params.get('preco_max') ? Number(params.get('preco_max')) : 0;
const filtroQuartos = params.get('quartos')   ? Number(params.get('quartos'))   : 0;

let todos = await db.select().from(imoveis).where(eq(imoveis.tenant_id, tenant.id));

// Apenas ativos
todos = todos.filter(i => i.status === 'disponivel' || i.status === 'ativo');

// Filtros
let exibir = todos;
if (filtroTipo)    exibir = exibir.filter(i => i.tipo === filtroTipo);
if (filtroBairro)  exibir = exibir.filter(i => i.bairro?.toLowerCase().includes(filtroBairro.toLowerCase()) || i.cidade?.toLowerCase().includes(filtroBairro.toLowerCase()));
if (filtroPreco)   exibir = exibir.filter(i => Number(i.preco) <= filtroPreco);
if (filtroQuartos) exibir = exibir.filter(i => (i.quartos ?? 0) >= filtroQuartos);

// Destaques primeiro
exibir = [...exibir].sort((a, b) => {
  if (a.destaque && !b.destaque) return -1;
  if (!a.destaque && b.destaque) return 1;
  return new Date(b.created_at ?? 0).getTime() - new Date(a.created_at ?? 0).getTime();
});

const totalVenda   = todos.filter(i => i.tipo === 'venda').length;
const totalAluguel = todos.filter(i => i.tipo === 'aluguel').length;
const temFiltro = !!(filtroTipo || filtroBairro || filtroPreco || filtroQuartos);
---

<SiteLayout title={`Imóveis — ${tenant.nome_empresa}`} tenant={tenant}>
  <SiteHeader tenant={tenant} currentPath="/imoveis" />

  <main class="imoveis-page">

    <!-- Page Header (fundo claro, igual ao original) -->
    <div class="page-hero">
      <div class="container">
        <span class="section-label">PORTFÓLIO</span>
        <h1 class="section-title">Nossos <span>Imóveis</span></h1>
        <p class="section-desc">
          {exibir.length} imóvel{exibir.length !== 1 ? 'is' : ''} encontrado{exibir.length !== 1 ? 's' : ''}
          {totalVenda > 0 && ` — ${totalVenda} à venda`}
          {totalAluguel > 0 && ` · ${totalAluguel} para alugar`}
        </p>
      </div>
    </div>

    <!-- Layout: Sidebar + Grid -->
    <div class="container imoveis-layout">

      <!-- SIDEBAR DE FILTROS -->
      <aside class="filtros-aside">
        <div class="filtros-card" id="filtros-card">
          <div class="filtros-header">
            <span class="filtros-title">Filtros</span>
            <div style="display:flex;gap:0.75rem;align-items:center;">
              {temFiltro && (
                <a href="/imoveis" class="filtros-limpar" id="limpar-filtros">Limpar</a>
              )}
              <button type="button" class="btn btn-sm btn-outline-dark mobile-filters-toggle" id="btn-toggle-filtros" style="display:none;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
              </button>
            </div>
          </div>

          <form method="get" id="filtros-form" class="filtros-body">
            <!-- Tipo de negócio -->
            <div class="filtro-grupo">
              <label class="filtro-label">Tipo de negócio</label>
              <select name="tipo" class="filtro-select" id="filtro-tipo">
                <option value="" selected={!filtroTipo}>Todos</option>
                <option value="venda" selected={filtroTipo === 'venda'}>À Venda</option>
                <option value="aluguel" selected={filtroTipo === 'aluguel'}>Para Alugar</option>
              </select>
            </div>

            <!-- Bairro ou cidade -->
            <div class="filtro-grupo">
              <label class="filtro-label" for="filtro-bairro">Bairro ou cidade</label>
              <input
                type="text"
                name="bairro"
                id="filtro-bairro"
                class="filtro-input"
                value={filtroBairro}
                placeholder="Ex: Jardim Europa"
              />
            </div>

            <!-- Preço máximo -->
            <div class="filtro-grupo">
              <label class="filtro-label">Preço máximo</label>
              <select name="preco_max" class="filtro-select" id="filtro-preco">
                <option value="" selected={!filtroPreco}>Sem limite</option>
                <option value="300000" selected={filtroPreco === 300000}>R$ 300.000</option>
                <option value="500000" selected={filtroPreco === 500000}>R$ 500.000</option>
                <option value="750000" selected={filtroPreco === 750000}>R$ 750.000</option>
                <option value="1000000" selected={filtroPreco === 1000000}>R$ 1.000.000</option>
                <option value="2000000" selected={filtroPreco === 2000000}>R$ 2.000.000</option>
                <option value="5000000" selected={filtroPreco === 5000000}>R$ 5.000.000+</option>
              </select>
            </div>

            <!-- Quartos mínimos -->
            <div class="filtro-grupo">
              <label class="filtro-label">Quartos mínimos</label>
              <select name="quartos" class="filtro-select" id="filtro-quartos">
                <option value="" selected={!filtroQuartos}>Qualquer</option>
                {([1,2,3,4] as const).map(n => (
                  <option value={String(n)} selected={filtroQuartos === n}>{n}+ quarto{n > 1 ? 's' : ''}</option>
                ))}
              </select>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;" id="aplicar-filtros">
              Aplicar filtros
            </button>
          </form>
        </div>
      </aside>

      <!-- GRID DE IMÓVEIS -->
      <div class="imoveis-grid-wrap">
        {exibir.length === 0 ? (
          <div class="empty-state">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <h3>Nenhum imóvel encontrado</h3>
            <p>Tente ajustar os filtros ou volte em breve.</p>
            <a href="/imoveis" class="btn btn-outline-dark btn-sm" style="margin-top:1.25rem;" id="ver-todos-btn">Ver todos</a>
          </div>
        ) : (
          <div class="imoveis-grid">
            {exibir.map((imovel, i) => (
              <div class="fade-in" style={`transition-delay:${i * 0.05}s`}>
                <PropertyCard imovel={imovel} />
              </div>
            ))}
          </div>
        )}
      </div>

    </div>
  </main>

  <SiteFooter tenant={tenant} />
</SiteLayout>

<script>
  // Mobile filters toggle
  const btnToggle = document.getElementById('btn-toggle-filtros');
  const filtrosBody = document.getElementById('filtros-form');
  if (btnToggle && filtrosBody) {
    btnToggle.addEventListener('click', () => {
      filtrosBody.classList.toggle('show-on-mobile');
    });
  }
</script>

<style>
  .imoveis-page {
    padding-top: 76px;
    padding-bottom: 5rem;
    background: var(--color-bg-alt);
    min-height: 100vh;
  }

  /* Page Header — fundo branco/claro igual ao original */
  .page-hero {
    background: var(--color-bg-alt);
    padding: var(--space-12) 0 var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }

  /* Layout principal: sidebar + grid */
  .imoveis-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    padding-top: 2rem;
    align-items: start;
  }

  /* Sidebar */
  .filtros-aside { }

  .filtros-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    position: sticky;
    top: 88px;
    box-shadow: var(--shadow-sm);
  }

  .filtros-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .filtros-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .filtros-limpar {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .filtros-limpar:hover { text-decoration: underline; }

  .filtro-grupo {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
  }

  .filtro-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .filtro-input,
  .filtro-select {
    width: 100%;
    padding: 0.6rem 0.875rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-family: var(--font-family);
    color: var(--color-text);
    background: white;
    outline: none;
    transition: border-color 0.2s;
    appearance: auto;
  }

  .filtro-input:focus,
  .filtro-select:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(13,110,253,0.08);
  }

  /* Grid de imóveis */
  .imoveis-grid-wrap { min-width: 0; }

  .imoveis-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-muted);
    background: white;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
  }

  .empty-state svg {
    display: block;
    margin: 0 auto 1.5rem;
    opacity: 0.3;
  }

  .empty-state h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .empty-state p { font-size: 0.875rem; }

  /* Responsive */
  @media (max-width: 1024px) {
    .imoveis-layout { grid-template-columns: 240px 1fr; gap: 1.5rem; }
  }

  @media (max-width: 768px) {
    .imoveis-layout { grid-template-columns: 1fr; }
    .filtros-card { position: static; }
    .filtros-aside { order: 0; }
    .imoveis-grid-wrap { order: 1; }
    .imoveis-grid { grid-template-columns: 1fr; }
    
    .mobile-filters-toggle { display: flex !important; }
    .filtros-body { display: none; }
    .filtros-body.show-on-mobile { display: block; }
  }

  @media (max-width: 480px) {
    .imoveis-grid { grid-template-columns: 1fr; }
  }
</style>
