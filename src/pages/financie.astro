---
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import { db } from '../lib/db';
import { bancos_financiamento } from '../lib/schema';
import { eq, asc } from 'drizzle-orm';

const tenant = (Astro.locals as any).tenant;
if (!tenant) return Astro.redirect('/');

const nome = tenant.nome_empresa ?? 'Imobiliária';
const wa = `https://wa.me/55${(tenant.whatsapp ?? '').replace(/\D/g,'')}?text=${encodeURIComponent('Olá! Gostaria de ajuda para simular um financiamento imobiliário.')}`;

const bancos = [
  { nome:'Caixa Econômica Federal', descricao:'Maior agente de financiamento habitacional do Brasil. Melhores taxas pelo programa Casa Verde e Amarela.', cor:'#005ca9', url:'https://www8.caixa.gov.br/siopiinternet-web/simulaOperacaoInternet.do?method=inicializarCasoUso', destaque:true, tag:'Mais popular', sigla:'CAIXA' },
  { nome:'Banco Itaú', descricao:'Crédito imobiliário com atendimento digital ágil, parcelas fixas e carência especial para novos imóveis.', cor:'#f47920', url:'https://credito-imobiliario.itau.com.br/proposta', destaque:false, tag:'', sigla:'itaú' },
  { nome:'Bradesco', descricao:'Financiamento com parcelas que cabem no seu bolso, prazo de até 35 anos e sem necessidade de conta corrente.', cor:'#cc092f', url:'https://banco.bradesco/html/classic/produtos-servicos/emprestimo-e-financiamento/encontre-seu-credito/simuladores-imoveis.shtm', destaque:false, tag:'', sigla:'bradesco' },
  { nome:'Santander', descricao:'Simulação 100% digital com resposta em minutos. Taxas competitivas e aprovação facilitada para servidores públicos.', cor:'#ec0000', url:'https://www.negociosimobiliarios.santander.com.br/negociosimobiliarios/#/dados-pessoais', destaque:false, tag:'', sigla:'Santander' },
  { nome:'Banco do Brasil', descricao:'Para servidores federais, militares e clientes BB com condições exclusivas e juros a partir de 8,99% a.a.', cor:'#003882', url:'https://cim-simulador-imovelproprio.apps.bb.com.br/simulacao-imobiliario/sobre-imovel', destaque:false, tag:'', sigla:'BB' },
  { nome:'Banrisul', descricao:'Crédito habitacional com atendimento personalizado, taxas especiais para clientes e programas do Governo Federal.', cor:'#00529b', url:'https://www.banrisul.com.br/brz/link/brzwswhn.html', destaque:false, tag:'', sigla:'Banrisul' },
];

const dicas = [
  { icone:'📋', titulo:'Reúna seus documentos', texto:'Tenha em mãos RG, CPF, comprovante de renda e extrato bancário dos últimos 3 meses.' },
  { icone:'💰', titulo:'Calcule a entrada', texto:'O valor mínimo de entrada geralmente é 20% do valor do imóvel. Quanto maior a entrada, menor os juros.' },
  { icone:'📊', titulo:'Verifique o score', texto:'Um bom score de crédito garante melhores taxas. Consulte o Serasa ou SPC antes de simular.' },
  { icone:'🏠', titulo:'Prazo de financiamento', texto:'Prazos mais longos reduzem a parcela, mas aumentam o valor total pago. Simule diferentes cenários.' },
];

const coresBancos: Record<string, { cor: string; bg: string; descricao: string; tag: string; destaque: boolean }> = {
  'Caixa Econômica Federal': { cor:'#005ca9', bg:'linear-gradient(140deg,#004a8f 0%,#0076cc 100%)', descricao:'Maior agente de crédito habitacional do Brasil. Taxas especiais pelo programa Casa Verde e Amarela.', tag:'Mais popular', destaque:true },
  'Banco do Brasil':         { cor:'#003882', bg:'linear-gradient(140deg,#002a6e 0%,#f5d600 100%)', descricao:'Condições exclusivas para servidores federais. Juros a partir de 8,99% ao ano.', tag:'', destaque:false },
  'Santander':               { cor:'#ec0000', bg:'linear-gradient(140deg,#b00000 0%,#ff3333 100%)', descricao:'Simulação 100% digital com resposta em minutos. Taxas competitivas e aprovação facilitada.', tag:'', destaque:false },
  'Bradesco':                { cor:'#cc092f', bg:'linear-gradient(140deg,#8e0020 0%,#d9103a 100%)', descricao:'Parcelas que cabem no seu bolso, prazo de até 35 anos e sem necessidade de conta corrente.', tag:'', destaque:false },
  'Itaú':                    { cor:'#f47920', bg:'linear-gradient(140deg,#002776 0%,#f47920 100%)', descricao:'Crédito imobiliário digital com parcelas fixas, carência especial e aprovação ágil.', tag:'', destaque:false },
  'Sicoob':                  { cor:'#007a3d', bg:'linear-gradient(140deg,#00582b 0%,#00b050 100%)', descricao:'Crédito habitacional cooperativo com atendimento personalizado e taxas diferenciadas para associados.', tag:'', destaque:false },
};

let bancosExibicao = [];
const bancosDB = await db.select().from(bancos_financiamento).where(eq(bancos_financiamento.tenant_id, tenant.id)).orderBy(asc(bancos_financiamento.ordem));

if (bancosDB.length > 0) {
  bancosExibicao = bancosDB.map(b => {
    const m = coresBancos[b.nome] ?? { cor:'#0d6efd', bg:'linear-gradient(140deg,#0d6efd,#0a58ca)', descricao:'', tag:'', destaque:false };
    return { nome:b.nome, descricao:m.descricao, cor:m.cor, bg:m.bg, url:b.link, destaque:m.destaque, tag:m.tag, sigla:b.nome.substring(0,2).toUpperCase(), logo_url:b.logo_url };
  });
} else {
  bancosExibicao = bancos.map(b => ({ ...b, bg: coresBancos[b.nome]?.bg ?? 'linear-gradient(140deg,#0d6efd,#0a58ca)' }));
}
---

<SiteLayout title={`Simule seu Financiamento — ${nome}`} description="Compare as taxas dos principais bancos e simule o financiamento do seu imóvel gratuitamente." tenant={tenant}>
  <SiteHeader tenant={tenant} currentPath="/financie" />

  <main style="padding-top:76px;">

    <!-- Hero -->
    <div class="fin-hero">
      <div class="container">
        <div class="hero-badge">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          FINANCIAMENTO IMOBILIÁRIO
        </div>
        <h1>Simule seu <span class="hero-hl">financiamento</span></h1>
        <p class="hero-desc">Compare as taxas dos principais bancos do Brasil e escolha a melhor opção para realizar o sonho da casa própria. Simulação gratuita e sem compromisso.</p>
        <div class="hero-stats">
          <div class="hstat"><strong>6</strong><span>bancos parceiros</span></div>
          <div class="hdiv"></div>
          <div class="hstat"><strong>35 anos</strong><span>prazo máximo</span></div>
          <div class="hdiv"></div>
          <div class="hstat"><strong>100%</strong><span>gratuito</span></div>
        </div>
      </div>
    </div>

    <!-- Grid bancos -->
    <div class="container">
      <div class="sec-intro">
        <h2>Escolha seu banco e simule agora</h2>
        <p>Clique no simulador do banco de sua preferência e calcule suas parcelas em minutos</p>
      </div>

      <div class="bancos-grid">
        {bancosExibicao.map(b => (
          <a href={b.url} target="_blank" rel="noopener noreferrer"
             class={`banco-card ${b.destaque ? 'banco-destaque' : ''}`}
             id={`banco-${b.sigla.toLowerCase().replace(/\s+/g,'')}`}>
            {b.tag && <div class="banco-tag">{b.tag}</div>}

            <!-- Topo colorido com logo -->
            <div class="banco-topo" style={`background:${b.bg};`}>
              <div class="banco-logo-wrap">
                {b.logo_url ? (
                  <div class="banco-logo-placa">
                    <img src={b.logo_url} alt={b.nome}
                      style="max-width:120px;max-height:52px;object-fit:contain;display:block;" />
                  </div>
                ) : (
                  <div class="banco-sigla">{b.sigla}</div>
                )}
              </div>
            </div>

            <!-- Corpo do card -->
            <div class="banco-body">
              <h3>{b.nome}</h3>
              {b.descricao && <p>{b.descricao}</p>}
            </div>

            <!-- Botão CTA -->
            <div class="banco-cta" style={`color:${b.cor};`}>
              <span>Simular agora</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </a>
        ))}
      </div>

      <!-- Aviso -->
      <div class="aviso">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0d6efd" stroke-width="2" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>Os simuladores acima redirecionam para os <strong>sites oficiais dos bancos</strong>. A {nome} não realiza intermediação financeira — nossa equipe pode te orientar na escolha e documentação. <a href="/contato">Fale com um especialista →</a></p>
      </div>
    </div>

    <!-- Dicas -->
    <div class="dicas-wrap">
      <div class="container">
        <div class="sec-intro">
          <h2>Dicas antes de simular</h2>
          <p>Prepare-se para obter as melhores condições de financiamento</p>
        </div>
        <div class="dicas-grid">
          {dicas.map(d => (
            <div class="dica-card fade-in">
              <div class="dica-icone">{d.icone}</div>
              <h3>{d.titulo}</h3>
              <p>{d.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="cta-dark">
      <div class="container cta-box">
        <div>
          <h2>Precisa de ajuda para escolher?</h2>
          <p>Nossos especialistas podem te orientar sobre qual banco oferece as melhores condições para o seu perfil.</p>
        </div>
        <div class="cta-actions">
          <a href="/contato" class="btn-white" id="financie-contato-btn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.09 6.09l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Falar com especialista
          </a>
          {tenant.whatsapp && (
            <a href={wa} target="_blank" class="btn-whatsapp" id="financie-whatsapp-btn">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          )}
        </div>
      </div>
    </div>

  </main>

  <SiteFooter tenant={tenant} />
</SiteLayout>

<style>
  /* Hero */
  .fin-hero { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #0d4fa8 100%); padding: 5rem 0 4rem; text-align: center; position: relative; overflow: hidden; }
  .fin-hero::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 70% 50%, rgba(13,110,253,.25) 0%, transparent 70%); }
  .fin-hero .container { position: relative; z-index: 1; }
  .hero-badge { display:inline-flex; align-items:center; gap:.5rem; background:rgba(13,110,253,.2); border:1px solid rgba(13,110,253,.4); color:#93c5fd; font-size:.72rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; padding:.4rem 1rem; border-radius:100px; margin-bottom:1.5rem; }
  .fin-hero h1 { font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; color: white; line-height: 1.1; margin-bottom: 1.25rem; }
  .hero-hl { color: #60a5fa; }
  .hero-desc { font-size: 1.05rem; color: rgba(255,255,255,.75); max-width: 600px; margin: 0 auto 2.5rem; line-height: 1.7; }
  .hero-stats { display:inline-flex; align-items:center; gap:2rem; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.12); border-radius:16px; padding:1rem 2rem; }
  .hstat { text-align:center; }
  .hstat strong { display:block; font-size:1.375rem; font-weight:800; color:white; }
  .hstat span { font-size:.75rem; color:rgba(255,255,255,.55); }
  .hdiv { width:1px; height:36px; background:rgba(255,255,255,.15); }

  /* Section intro */
  .sec-intro { text-align:center; padding:3.5rem 0 2.5rem; }
  .sec-intro h2 { font-size:1.625rem; font-weight:800; color:var(--color-text); margin-bottom:.5rem; }
  .sec-intro p { font-size:.95rem; color:var(--color-muted); }

  /* Bancos */
  .bancos-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-bottom:1.5rem; }

  .banco-card {
    background: white;
    border: 1.5px solid #e5e7eb;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform .25s cubic-bezier(.34,1.56,.64,1), box-shadow .25s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  .banco-card:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow: 0 20px 48px rgba(0,0,0,.14);
  }
  .banco-destaque { border-color:#0d6efd; box-shadow:0 4px 24px rgba(13,110,253,.18); }
  .banco-tag {
    position: absolute; top: 14px; right: 14px; z-index: 2;
    background: rgba(255,255,255,.25); backdrop-filter: blur(8px);
    color: white; font-size: .65rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: .08em;
    padding: .3rem .75rem; border-radius: 100px;
    border: 1px solid rgba(255,255,255,.4);
  }

  /* Topo colorido */
  .banco-topo {
    position: relative;
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .banco-topo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 30%, rgba(255,255,255,.15) 0%, transparent 65%);
  }
  .banco-logo-wrap {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 1.25rem 1.5rem;
  }
  .banco-logo-placa {
    background: white;
    border-radius: 14px;
    padding: 1rem 1.75rem;
    box-shadow: 0 4px 20px rgba(0,0,0,.18);
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 140px;
    min-height: 72px;
  }
  .banco-sigla {
    font-size: 2.5rem;
    font-weight: 900;
    color: white;
    letter-spacing: -.04em;
    text-shadow: 0 2px 8px rgba(0,0,0,.2);
  }

  /* Corpo */
  .banco-body { padding: 1.25rem 1.4rem; flex: 1; }
  .banco-body h3 {
    font-size: .975rem; font-weight: 700;
    color: #111827; margin-bottom: .45rem;
  }
  .banco-body p { font-size: .8rem; color: #6b7280; line-height: 1.65; }

  /* CTA inferior */
  .banco-cta {
    display: flex; align-items: center; justify-content: space-between;
    padding: .9rem 1.4rem;
    border-top: 1px solid #f3f4f6;
    font-size: .875rem; font-weight: 700;
    transition: background .18s, padding-right .18s;
  }
  .banco-cta svg { transition: transform .2s; }
  .banco-card:hover .banco-cta { background: #f9fafb; padding-right: 1rem; }
  .banco-card:hover .banco-cta svg { transform: translateX(4px); }

  /* Aviso */
  .aviso { display:flex; align-items:flex-start; gap:.875rem; background:#eff6ff; border:1.5px solid #bfdbfe; border-radius:12px; padding:1rem 1.25rem; margin-bottom:4rem; font-size:.85rem; color:#1e3a5f; line-height:1.6; }
  .aviso a { color:#0d6efd; font-weight:600; }

  /* Dicas */
  .dicas-wrap { background:var(--color-bg-alt); border-top:1px solid var(--color-border); border-bottom:1px solid var(--color-border); padding-bottom:4rem; }
  .dicas-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.25rem; }
  .dica-card { background:white; border:1px solid var(--color-border); border-radius:12px; padding:1.5rem; transition:box-shadow .18s; }
  .dica-card:hover { box-shadow:0 4px 16px rgba(0,0,0,.07); }
  .dica-icone { font-size:2rem; margin-bottom:.875rem; display:block; }
  .dica-card h3 { font-size:.9rem; font-weight:700; color:var(--color-text); margin-bottom:.5rem; }
  .dica-card p { font-size:.82rem; color:var(--color-muted); line-height:1.6; }

  /* CTA */
  .cta-dark { padding:4rem 0; background:linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); }
  .cta-box { display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
  .cta-box h2 { font-size:1.5rem; font-weight:800; color:white; margin-bottom:.5rem; }
  .cta-box p { font-size:.9rem; color:rgba(255,255,255,.65); max-width:500px; }
  .cta-actions { display:flex; gap:.875rem; flex-wrap:wrap; }
  .btn-white { display:inline-flex; align-items:center; gap:.5rem; background:white; color:#0f172a; padding:.75rem 1.5rem; border-radius:8px; font-weight:700; font-size:.9rem; text-decoration:none; transition:all .18s; }
  .btn-white:hover { background:#f1f5f9; transform:translateY(-1px); }
  .btn-whatsapp { display:inline-flex; align-items:center; gap:.5rem; background:#25d366; color:white; padding:.75rem 1.5rem; border-radius:8px; font-weight:700; font-size:.9rem; text-decoration:none; transition:all .18s; }
  .btn-whatsapp:hover { background:#20b859; transform:translateY(-1px); }

  @media (max-width:1024px) {
    .bancos-grid { grid-template-columns:repeat(2,1fr); }
    .dicas-grid { grid-template-columns:repeat(2,1fr); }
    .cta-box { flex-direction:column; text-align:center; }
  }
  @media (max-width:640px) {
    .bancos-grid { grid-template-columns:1fr; }
    .dicas-grid { grid-template-columns:1fr; }
    .hero-stats { flex-direction:column; gap:.75rem; }
    .hdiv { width:80px; height:1px; }
    .cta-actions { width:100%; flex-direction:column; }
  }
</style>
