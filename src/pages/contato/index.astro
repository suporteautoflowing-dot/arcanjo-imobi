---
/**
 * Página de Contato — fiel ao layout original da Arcanjo Imóveis
 * Formulário à esquerda (maior) + card de info à direita (sticky)
 */
import SiteLayout from '../../layouts/SiteLayout.astro';
import SiteHeader from '../../components/site/SiteHeader.astro';
import SiteFooter from '../../components/site/SiteFooter.astro';
import { db } from '../../lib/db';
import { leads } from '../../lib/schema';

const tenant = (Astro.locals as any).tenant;
if (!tenant) return Astro.redirect('/');

const wa = `https://wa.me/55${(tenant.whatsapp ?? '').replace(/\D/g, '')}?text=${encodeURIComponent(`Olá! Gostaria de falar com um especialista da ${tenant.nome_empresa}.`)}`;

let sent = false;
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const nome = form.get('nome')?.toString() ?? '';
  if (nome) {
    await db.insert(leads).values({
      tenant_id: tenant.id,
      nome,
      email:    form.get('email')?.toString(),
      whatsapp: form.get('telefone')?.toString(),
      mensagem: `[${form.get('assunto') ?? 'contato'}] ${form.get('mensagem') ?? ''}`,
      origem:   'contato',
      status:   'novo',
    });
    sent = true;
  }
}
---

<SiteLayout title={`Contato — ${tenant.nome_empresa}`} description={`Entre em contato com ${tenant.nome_empresa}. Estamos prontos para te ajudar.`} tenant={tenant}>
  <SiteHeader tenant={tenant} currentPath="/contato" />

  <main class="contact-page">
    <!-- Page Hero -->
    <div class="page-hero">
      <div class="container">
        <span class="section-label">FALE CONOSCO</span>
        <h1 class="section-title">Entre em <span>Contato</span></h1>
        <p class="section-desc">Nossa equipe está pronta para te ajudar. Responderemos em até 2 horas úteis.</p>
      </div>
    </div>

    <div class="container contact-layout">
      <!-- Formulário -->
      <div class="contact-form-wrap">
        {sent ? (
          <div style="text-align:center;padding:4rem 2rem;background:white;border:1px solid var(--color-border);border-radius:var(--radius-xl);">
            <div style="font-size:3.5rem;margin-bottom:1rem;">✅</div>
            <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:0.5rem;">Mensagem enviada!</h2>
            <p style="color:var(--color-muted);margin-bottom:1.5rem;">Entraremos em contato em breve. Obrigado!</p>
            <a href="/contato" class="btn btn-outline-dark btn-sm">Enviar outra mensagem</a>
          </div>
        ) : (
          <form id="contact-form" class="contact-form" method="POST" novalidate>
            <div class="form-row">
              <div class="form-group-pub">
                <label class="form-label-pub" for="contact-nome">Nome completo *</label>
                <input type="text" id="contact-nome" name="nome" class="form-input-pub" placeholder="Seu nome" required />
              </div>
              <div class="form-group-pub">
                <label class="form-label-pub" for="contact-email">E-mail *</label>
                <input type="email" id="contact-email" name="email" class="form-input-pub" placeholder="seu@email.com" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group-pub">
                <label class="form-label-pub" for="contact-telefone">Telefone / WhatsApp</label>
                <input type="tel" id="contact-telefone" name="telefone" class="form-input-pub" placeholder="(11) 9 9999-9999" />
              </div>
              <div class="form-group-pub">
                <label class="form-label-pub" for="contact-assunto">Assunto *</label>
                <select id="contact-assunto" name="assunto" class="form-input-pub form-select-pub" required>
                  <option value="">Selecione</option>
                  <option value="compra">Quero comprar um imóvel</option>
                  <option value="aluguel">Quero alugar um imóvel</option>
                  <option value="vender">Quero vender meu imóvel</option>
                  <option value="visita">Agendar uma visita</option>
                  <option value="outro">Outro assunto</option>
                </select>
              </div>
            </div>
            <div class="form-group-pub">
              <label class="form-label-pub" for="contact-mensagem">Mensagem *</label>
              <textarea id="contact-mensagem" name="mensagem" class="form-input-pub form-textarea-pub" placeholder="Descreva como podemos te ajudar..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-lg" id="contact-submit-btn" style="width:100%;justify-content:center;">
              Enviar mensagem
            </button>
            <p id="form-feedback" class="form-feedback" aria-live="polite"></p>
          </form>
        )}
      </div>

      <!-- Info sidebar -->
      <aside class="contact-info">
        <div class="info-card">
          <h2 class="info-card-title">Informações de contato</h2>
          <ul class="info-list">
            {tenant.whatsapp && (
              <li>
                <div class="info-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9c1.24 2.4 3.12 4.29 5.52 5.52l1.18-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </div>
                <div>
                  <strong>WhatsApp</strong>
                  <span>{tenant.whatsapp}</span>
                </div>
              </li>
            )}
            {tenant.email && (
              <li>
                <div class="info-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div>
                  <strong>E-mail</strong>
                  <span>{tenant.email}</span>
                </div>
              </li>
            )}
            {tenant.endereco && (
              <li>
                <div class="info-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <strong>Endereço</strong>
                  <span>{tenant.endereco}</span>
                </div>
              </li>
            )}
            {tenant.horario && (
              <li>
                <div class="info-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <div>
                  <strong>Horário de atendimento</strong>
                  <span>{tenant.horario}</span>
                </div>
              </li>
            )}
          </ul>

          {tenant.whatsapp && (
            <a href={wa} target="_blank" rel="noopener noreferrer"
               class="btn btn-primary"
               style="width:100%;justify-content:center;margin-top:2rem;"
               id="contact-page-whatsapp-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chamar no WhatsApp
            </a>
          )}
        </div>
      </aside>
    </div>
  </main>

  <SiteFooter tenant={tenant} />
</SiteLayout>

<style>
  .contact-page { padding-top: 76px; }

  .page-hero {
    background: var(--color-bg-alt);
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 3rem;
    padding-bottom: 5rem;
    align-items: start;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group-pub { display: flex; flex-direction: column; gap: 0.4rem; }

  .form-label-pub {
    font-size: 0.875rem; font-weight: 600; color: var(--color-text);
  }

  .form-input-pub {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    font-size: var(--font-size-base);
    font-family: var(--font-family);
    color: var(--color-text);
    background: white;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }

  .form-input-pub:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .form-select-pub { appearance: none; cursor: pointer; }
  .form-textarea-pub { resize: vertical; min-height: 140px; }

  .form-feedback { font-size: 0.875rem; font-weight: 500; min-height: 1.5rem; margin-top: 0.25rem; }

  /* Info sidebar */
  .info-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2rem;
    position: sticky;
    top: 100px;
  }

  .info-card-title { font-size: 1.1rem; font-weight: 700; color: var(--color-text); margin-bottom: 1.5rem; }

  .info-list { display: flex; flex-direction: column; gap: 1.25rem; list-style: none; }

  .info-list li { display: flex; align-items: flex-start; gap: 1rem; }

  .info-icon {
    width: 44px; height: 44px; border-radius: var(--radius);
    background: var(--color-primary-light); color: var(--color-primary);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }

  .info-list strong { display: block; font-size: 0.875rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.125rem; }
  .info-list span { font-size: 0.875rem; color: var(--color-muted); }

  @media (max-width: 1024px) {
    .contact-layout { grid-template-columns: 1fr; }
    .info-card { position: static; }
  }
  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>
