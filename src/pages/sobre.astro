---
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import { db } from '../lib/db';

const tenant = (Astro.locals as any).tenant;
if (!tenant) return Astro.redirect('/');

const nome = tenant.nome_empresa ?? 'Imobiliária';
const wa = `https://wa.me/55${(tenant.whatsapp ?? '').replace(/\D/g,'')}`;

const valores = [
  { icone: '🎯', titulo: 'Missão', texto: 'Conectar pessoas aos imóveis ideais com transparência, agilidade e excelência no atendimento.' },
  { icone: '🌟', titulo: 'Visão', texto: 'Ser a imobiliária de referência na região, reconhecida pela confiança e pelos resultados.' },
  { icone: '💎', titulo: 'Valores', texto: 'Ética, transparência, comprometimento e foco total na satisfação de cada cliente.' },
];

const diferenciais = [
  { num: '01', titulo: 'Especialistas Locais', texto: 'Conhecimento profundo do mercado imobiliário local para encontrar o imóvel certo para você.' },
  { num: '02', titulo: 'Atendimento Personalizado', texto: 'Cada cliente recebe atenção exclusiva do início ao fim da negociação.' },
  { num: '03', titulo: 'Total Transparência', texto: 'Sem surpresas. Documentação clara, processos honestos e comunicação aberta em todas as etapas.' },
  { num: '04', titulo: 'Agilidade e Tecnologia', texto: 'Plataforma digital completa para buscar, visitar e fechar negócio com rapidez e segurança.' },
];

const depoimentos = [
  { texto: 'Equipe incrível! Encontraram o apartamento perfeito em menos de 2 semanas. Super recomendo!', nome: 'Mariana Costa', cidade: 'Cliente satisfeita', estrelas: 5 },
  { texto: 'Processo de compra sem burocracia e com total suporte. Excelentes profissionais!', nome: 'Roberto Ferreira', cidade: 'Cliente satisfeito', estrelas: 5 },
  { texto: 'Aluguei meu imóvel em tempo recorde e com ótimo valor. Equipe atenciosa e eficiente!', nome: 'Camila Nunes', cidade: 'Cliente satisfeita', estrelas: 5 },
];

const stats = [
  { valor: 10, sufixo: '+', label: 'Anos de mercado' },
  { valor: 1200, sufixo: '+', label: 'Clientes atendidos' },
  { valor: 500, sufixo: '+', label: 'Imóveis negociados' },
  { valor: 98, sufixo: '%', label: 'Índice de satisfação' },
];
---

<SiteLayout title={`Sobre Nós — ${nome}`} description={`Conheça ${nome}: nossa história, missão, equipe e valores.`} tenant={tenant}>
  <SiteHeader tenant={tenant} currentPath="/sobre" />

  <main style="padding-top:76px;">

    <!-- 1. HERO -->
    <section class="sobre-hero">
      <div class="sobre-hero-bg"></div>
      <div class="container sobre-hero-content">
        <span class="section-label" style="color:#93c5fd;">QUEM SOMOS</span>
        <h1>Realizando <span style="color:#60a5fa;">sonhos</span> há mais de uma década</h1>
        <p>{nome} nasceu da paixão por conectar pessoas aos lugares certos. Com expertise, ética e cuidado, transformamos a busca pelo imóvel ideal numa experiência positiva e segura.</p>
        <div class="hero-pills">
          <span class="pill">📅 Desde 2014</span>
          <span class="pill">⭐ 98% de satisfação</span>
          {tenant.cidade && <span class="pill">📍 {tenant.cidade}</span>}
        </div>
      </div>
    </section>

    <!-- 2. MISSÃO VISÃO VALORES -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-header">
          <span class="section-label">NOSSOS PRINCÍPIOS</span>
          <h2 class="section-title">Missão, Visão e <span>Valores</span></h2>
        </div>
        <div class="mvv-grid">
          {valores.map(v => (
            <div class="mvv-card fade-in">
              <div class="mvv-icone">{v.icone}</div>
              <h3>{v.titulo}</h3>
              <p>{v.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. DIFERENCIAIS (dark) -->
    <section class="dif-section">
      <div class="container">
        <div class="section-header">
          <span class="section-label" style="color:#93c5fd;">POR QUE NOS ESCOLHER</span>
          <h2 class="section-title" style="color:white;">Nossos <span style="color:#60a5fa;">diferenciais</span></h2>
        </div>
        <div class="dif-grid">
          {diferenciais.map(d => (
            <div class="dif-item fade-in">
              <span class="dif-num">{d.num}</span>
              <h3>{d.titulo}</h3>
              <p>{d.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. NÚMEROS -->
    <section class="section section-alt">
      <div class="container numeros-grid" id="numeros-section">
        {stats.map(s => (
          <div class="numero-item">
            <strong class="numero-valor" data-target={s.valor} data-sufixo={s.sufixo}>0{s.sufixo}</strong>
            <span class="numero-label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- 5. DEPOIMENTOS -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="section-label">O QUE DIZEM NOSSOS CLIENTES</span>
          <h2 class="section-title">Histórias de <span>sucesso</span></h2>
        </div>
        <div class="dep-grid">
          {depoimentos.map(d => (
            <div class="dep-card fade-in">
              <div class="dep-estrelas">{'★'.repeat(d.estrelas)}</div>
              <p class="dep-texto">"{d.texto}"</p>
              <div class="dep-autor">
                <strong>{d.nome}</strong>
                <span>{d.cidade}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 6. CTA FINAL -->
    <section class="cta-dark">
      <div class="container cta-box">
        <div>
          <h2>Pronto para realizar seu <span style="color:#93c5fd;">sonho</span>?</h2>
          <p>Nossa equipe está pronta para te atender e encontrar o imóvel ideal para você.</p>
        </div>
        <div class="cta-actions">
          <a href="/imoveis" class="btn-white" id="sobre-ver-imoveis">Ver imóveis</a>
          {tenant.whatsapp && (
            <a href={wa} target="_blank" class="btn-whatsapp" id="sobre-whatsapp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          )}
        </div>
      </div>
    </section>

  </main>

  <SiteFooter tenant={tenant} />
</SiteLayout>

<script>
  const section = document.getElementById('numeros-section');
  if (section) {
    const obs = new IntersectionObserver(([e]) => {
      if (!e.isIntersecting) return;
      obs.disconnect();
      section.querySelectorAll<HTMLElement>('.numero-valor').forEach(el => {
        const target = Number(el.dataset.target);
        const suf = el.dataset.sufixo ?? '';
        let cur = 0;
        const step = Math.ceil(target / 110);
        const t = setInterval(() => {
          cur = Math.min(cur + step, target);
          el.textContent = cur.toLocaleString('pt-BR') + suf;
          if (cur >= target) clearInterval(t);
        }, 16);
      });
    }, { threshold: 0.3 });
    obs.observe(section);
  }
</script>

<style>
  .section-header { text-align: center; margin-bottom: 3rem; }

  /* Hero */
  .sobre-hero { position: relative; background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); padding: 5rem 0 4rem; text-align: center; overflow: hidden; }
  .sobre-hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 60% 50%, rgba(13,110,253,.2), transparent 70%); }
  .sobre-hero-content { position: relative; z-index: 1; }
  .sobre-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; color: white; margin: .75rem 0 1.25rem; line-height: 1.15; }
  .sobre-hero p { color: rgba(255,255,255,.75); font-size: 1.05rem; max-width: 580px; margin: 0 auto 2rem; line-height: 1.7; }
  .hero-pills { display: flex; justify-content: center; gap: .75rem; flex-wrap: wrap; }
  .pill { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15); color: white; padding: .4rem 1rem; border-radius: 100px; font-size: .82rem; font-weight: 500; }

  /* MVV */
  .mvv-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .mvv-card { background: white; border: 1.5px solid var(--color-border); border-radius: 16px; padding: 2rem; text-align: center; transition: box-shadow .2s, transform .2s; }
  .mvv-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); transform: translateY(-4px); }
  .mvv-icone { font-size: 2.5rem; display: block; margin-bottom: 1rem; }
  .mvv-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: .75rem; color: var(--color-text); }
  .mvv-card p { color: var(--color-muted); font-size: .875rem; line-height: 1.7; }

  /* Diferenciais */
  .dif-section { padding: 5rem 0; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
  .dif-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .dif-item { padding: 1.75rem; border: 1px solid rgba(255,255,255,.08); border-radius: 12px; background: rgba(255,255,255,.04); transition: background .2s; }
  .dif-item:hover { background: rgba(255,255,255,.08); }
  .dif-num { font-size: 2.5rem; font-weight: 900; color: #3b82f6; opacity: .6; display: block; line-height: 1; margin-bottom: .75rem; }
  .dif-item h3 { font-size: 1.05rem; font-weight: 700; color: white; margin-bottom: .5rem; }
  .dif-item p { color: rgba(255,255,255,.6); font-size: .875rem; line-height: 1.7; }

  /* Números */
  .numeros-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center; }
  .numero-item {}
  .numero-valor { display: block; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; color: var(--color-primary); line-height: 1; margin-bottom: .5rem; }
  .numero-label { font-size: .875rem; color: var(--color-muted); font-weight: 500; }

  /* Depoimentos */
  .dep-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .dep-card { background: white; border: 1.5px solid var(--color-border); border-radius: 16px; padding: 2rem; }
  .dep-estrelas { color: #f59e0b; font-size: 1.1rem; margin-bottom: .875rem; }
  .dep-texto { color: var(--color-text); font-size: .9rem; line-height: 1.75; font-style: italic; margin-bottom: 1.25rem; }
  .dep-autor strong { display: block; font-size: .875rem; font-weight: 700; }
  .dep-autor span { font-size: .78rem; color: var(--color-muted); }

  /* CTA */
  .cta-dark { padding: 4rem 0; background: linear-gradient(135deg, #0f172a, #1e3a5f); }
  .cta-box { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .cta-box h2 { font-size: 1.625rem; font-weight: 800; color: white; margin-bottom: .5rem; }
  .cta-box p { color: rgba(255,255,255,.65); font-size: .9rem; max-width: 480px; }
  .cta-actions { display: flex; gap: .875rem; flex-wrap: wrap; }
  .btn-white { display: inline-flex; align-items: center; gap: .5rem; background: white; color: #0f172a; padding: .75rem 1.5rem; border-radius: 8px; font-weight: 700; font-size: .9rem; text-decoration: none; transition: all .18s; }
  .btn-white:hover { background: #f1f5f9; transform: translateY(-1px); }
  .btn-whatsapp { display: inline-flex; align-items: center; gap: .5rem; background: #25d366; color: white; padding: .75rem 1.5rem; border-radius: 8px; font-weight: 700; font-size: .9rem; text-decoration: none; transition: all .18s; }
  .btn-whatsapp:hover { background: #20b859; transform: translateY(-1px); }

  @media (max-width: 1024px) {
    .mvv-grid, .dep-grid { grid-template-columns: 1fr 1fr; }
    .numeros-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-box { flex-direction: column; text-align: center; }
  }
  @media (max-width: 640px) {
    .mvv-grid, .dep-grid, .dif-grid { grid-template-columns: 1fr; }
    .numeros-grid { grid-template-columns: 1fr 1fr; }
    .cta-actions { width: 100%; flex-direction: column; }
    .btn-white, .btn-whatsapp { justify-content: center; }
  }
</style>
