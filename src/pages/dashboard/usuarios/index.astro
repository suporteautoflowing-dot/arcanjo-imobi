---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAuthFromCookie, hashPassword } from '../../../lib/auth';
import { db } from '../../../lib/db';
import { users } from '../../../lib/schema';
import { eq, desc } from 'drizzle-orm';

const auth = getAuthFromCookie(Astro.request);
if (!auth) return Astro.redirect('/auth/login');

let successMsg = '';
let errorMsg   = '';

// ── Ações POST ──
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const acao = String(form.get('acao') ?? '');

  if (acao === 'criar') {
    const nome   = String(form.get('nome')  ?? '').trim();
    const email  = String(form.get('email') ?? '').trim().toLowerCase();
    const senha  = String(form.get('senha') ?? '');
    const role   = String(form.get('role')  ?? 'admin');

    if (!nome || !email || !senha) {
      errorMsg = 'Preencha nome, e-mail e senha.';
    } else if (senha.length < 6) {
      errorMsg = 'A senha deve ter pelo menos 6 caracteres.';
    } else {
      const [existe] = await db.select().from(users).where(eq(users.email, email)).limit(1);
      if (existe) {
        errorMsg = 'Já existe um usuário com este e-mail.';
      } else {
        const hash = await hashPassword(senha);
        await db.insert(users).values({
          id: crypto.randomUUID(),
          nome, email, password_hash: hash, role, ativo: true,
        });
        successMsg = `Usuário "${nome}" criado com sucesso!`;
      }
    }
  }

  if (acao === 'toggle_ativo') {
    const uid   = String(form.get('uid') ?? '');
    const ativo = form.get('ativo') === '1';
    if (uid && uid !== auth.userId) {
      await db.update(users).set({ ativo: !ativo }).where(eq(users.id, uid));
      successMsg = `Usuário ${ativo ? 'desativado' : 'reativado'} com sucesso!`;
    } else if (uid === auth.userId) {
      errorMsg = 'Você não pode desativar a si mesmo.';
    }
  }

  if (acao === 'excluir') {
    const uid = String(form.get('uid') ?? '');
    if (uid && uid !== auth.userId) {
      await db.delete(users).where(eq(users.id, uid));
      successMsg = 'Usuário excluído.';
    } else {
      errorMsg = 'Você não pode excluir a si mesmo.';
    }
  }
}

const lista = await db.select().from(users).orderBy(desc(users.created_at));
---

<AdminLayout title="Usuários" breadcrumb="Dashboard / Usuários">

  {successMsg && (
    <div style="background:#dcfce7;border:1px solid #86efac;border-radius:8px;padding:.875rem 1rem;margin-bottom:1.25rem;color:#166534;font-weight:500;font-size:.875rem;">
      ✓ {successMsg}
    </div>
  )}
  {errorMsg && (
    <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:.875rem 1rem;margin-bottom:1.25rem;color:#991b1b;font-weight:500;font-size:.875rem;">
      ✕ {errorMsg}
    </div>
  )}

  <div class="grid-2" style="gap:1.5rem;align-items:start;">

    <!-- Lista de usuários -->
    <div class="card" style="grid-column:1/-1;">
      <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
        <span class="card-title">Usuários do Sistema</span>
        <span style="font-size:.75rem;color:var(--muted);">{lista.length} usuário{lista.length !== 1 ? 's' : ''}</span>
      </div>
      <div style="overflow-x:auto;">
        <table class="usr-table">
          <thead>
            <tr>
              <th>Nome</th>
              <th>E-mail</th>
              <th>Perfil</th>
              <th>Status</th>
              <th>Criado em</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            {lista.map(u => (
              <tr class={u.ativo ? '' : 'usr-row-inactive'}>
                <td>
                  <div class="usr-avatar-row">
                    <div class="usr-avatar" style={`background:${u.role === 'admin' ? '#2563eb' : '#7c3aed'};`}>
                      {u.nome.charAt(0).toUpperCase()}
                    </div>
                    <span class="usr-nome">{u.nome}</span>
                    {u.id === auth.userId && <span class="usr-you">você</span>}
                  </div>
                </td>
                <td class="usr-email">{u.email}</td>
                <td>
                  <span class={`usr-role ${u.role}`}>{u.role === 'admin' ? 'Admin' : 'Corretor'}</span>
                </td>
                <td>
                  <span class={`usr-status ${u.ativo ? 'ativo' : 'inativo'}`}>
                    {u.ativo ? 'Ativo' : 'Inativo'}
                  </span>
                </td>
                <td class="usr-data">{u.created_at.toLocaleDateString('pt-BR')}</td>
                <td>
                  {u.id !== auth.userId && (
                    <div style="display:flex;gap:.5rem;">
                      <form method="POST" style="display:inline;">
                        <input type="hidden" name="acao" value="toggle_ativo" />
                        <input type="hidden" name="uid" value={u.id} />
                        <input type="hidden" name="ativo" value={u.ativo ? '1' : '0'} />
                        <button type="submit" class={`usr-btn ${u.ativo ? 'warn' : 'success'}`}
                          title={u.ativo ? 'Desativar' : 'Reativar'}>
                          {u.ativo ? '⏸' : '▶'}
                        </button>
                      </form>
                      <form method="POST" style="display:inline;"
                        onsubmit="return confirm('Excluir este usuário permanentemente?')">
                        <input type="hidden" name="acao" value="excluir" />
                        <input type="hidden" name="uid" value={u.id} />
                        <button type="submit" class="usr-btn danger" title="Excluir">🗑</button>
                      </form>
                    </div>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Formulário novo usuário -->
    <div class="card" style="max-width:480px;">
      <div class="card-header"><span class="card-title">➕ Novo Usuário</span></div>
      <form method="POST">
        <input type="hidden" name="acao" value="criar" />
        <div class="card-body" style="display:flex;flex-direction:column;gap:1rem;">
          <div class="form-group">
            <label class="form-label">Nome completo</label>
            <input name="nome" class="form-input" placeholder="João Silva" required />
          </div>
          <div class="form-group">
            <label class="form-label">E-mail</label>
            <input name="email" type="email" class="form-input" placeholder="joao@imobiliaria.com" required />
          </div>
          <div class="form-group">
            <label class="form-label">Senha inicial</label>
            <input name="senha" type="password" class="form-input" placeholder="Mínimo 6 caracteres" required minlength="6" />
            <span class="form-hint">O usuário poderá alterar depois.</span>
          </div>
          <div class="form-group">
            <label class="form-label">Perfil</label>
            <select name="role" class="form-input">
              <option value="admin">Admin — acesso total</option>
              <option value="corretor">Corretor — acesso limitado</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-full">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Criar Usuário
          </button>
        </div>
      </form>
    </div>

    <!-- Info -->
    <div class="card" style="max-width:480px;">
      <div class="card-header"><span class="card-title">ℹ️ Informações</span></div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:.875rem;font-size:.85rem;color:var(--muted);line-height:1.6;">
        <div>
          <strong style="color:var(--text);">👤 Admin</strong><br/>
          Acesso completo ao painel: imóveis, leads, financeiro, configurações e usuários.
        </div>
        <div>
          <strong style="color:var(--text);">🏠 Corretor</strong><br/>
          Acesso restrito: pode gerenciar imóveis e visualizar leads, sem acesso a finanças e configurações.
        </div>
        <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:8px;padding:.75rem;">
          ⚠️ <strong>Atenção:</strong> Você não pode excluir ou desativar sua própria conta.
        </div>
      </div>
    </div>

  </div>
</AdminLayout>

<style>
  .usr-table {
    width: 100%; border-collapse: collapse; font-size: .875rem;
  }
  .usr-table th {
    text-align: left; padding: .75rem 1.25rem;
    font-size: .72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .06em; color: var(--muted);
    border-bottom: 1px solid var(--border);
  }
  .usr-table td {
    padding: .875rem 1.25rem; border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .usr-table tbody tr:last-child td { border-bottom: none; }
  .usr-table tbody tr:hover { background: var(--bg-alt, #f9fafb); }
  .usr-row-inactive td { opacity: .55; }

  .usr-avatar-row { display: flex; align-items: center; gap: .625rem; }
  .usr-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    color: white; font-weight: 800; font-size: .8rem;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .usr-nome { font-weight: 600; color: var(--text); }
  .usr-you {
    font-size: .65rem; background: #eff6ff; color: #2563eb;
    padding: .1rem .45rem; border-radius: 99px; font-weight: 700;
  }
  .usr-email { color: var(--muted); }
  .usr-data  { color: var(--muted); font-size: .8rem; }

  .usr-role {
    font-size: .72rem; font-weight: 700; padding: .2rem .6rem;
    border-radius: 99px; text-transform: uppercase; letter-spacing: .05em;
  }
  .usr-role.admin    { background: #eff6ff; color: #2563eb; }
  .usr-role.corretor { background: #f5f3ff; color: #7c3aed; }

  .usr-status {
    font-size: .75rem; font-weight: 700; padding: .2rem .6rem;
    border-radius: 99px;
  }
  .usr-status.ativo   { background: #dcfce7; color: #166534; }
  .usr-status.inativo { background: #f3f4f6; color: #6b7280; }

  .usr-btn {
    width: 30px; height: 30px; border-radius: 7px;
    border: 1px solid var(--border); background: var(--card-bg, #fff);
    cursor: pointer; font-size: .875rem; display: flex; align-items: center;
    justify-content: center; transition: all .15s;
  }
  .usr-btn.warn:hover    { background: #fef3c7; border-color: #f59e0b; }
  .usr-btn.success:hover { background: #dcfce7; border-color: #16a34a; }
  .usr-btn.danger:hover  { background: #fee2e2; border-color: #dc2626; }
</style>
