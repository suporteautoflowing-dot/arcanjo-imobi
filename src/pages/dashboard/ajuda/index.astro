---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import TutorialCard from '../../../components/TutorialCard.astro';
import { getAuthFromCookie } from '../../../lib/auth';

const auth = getAuthFromCookie(Astro.request);
if (!auth) return Astro.redirect('/auth/login');

// URLs das imagens dos tutoriais (arquivos permanentes no git)
const IMG = {
  dashboard: '/uploads/tut-dashboard.png',
  imovel:    '/uploads/tut-imovel.png',
  leads:     '/uploads/tut-leads.png',
  banner:    '/uploads/tut-banner.png',
  config:    '/uploads/tut-config.png',
};

const tutoriais = [
  // ── Primeiros Passos ──
  {
    aba: 'primeiros-passos',
    titulo: 'Conhecendo o Dashboard',
    descricao: 'Entenda a tela principal do painel: estatísticas, atalhos e relatórios em tempo real.',
    categoria: 'Primeiros Passos',
    dificuldade: 'Fácil' as const,
    cor: '#7c3aed',
    imagens: [IMG.dashboard],
    passos: [
      { texto: 'Acesse o painel em /auth/login com seu e-mail e senha.' },
      { texto: 'Na tela inicial você vê os totais de imóveis, leads e novidades.' },
      { texto: 'Use os "Atalhos Rápidos" no rodapé para navegar rapidamente.' },
      { texto: 'O menu lateral esquerdo é seu principal guia de navegação.' },
    ],
    link: '/dashboard',
    linkLabel: 'Abrir Dashboard',
  },

  // ── Imóveis ──
  {
    aba: 'imoveis',
    titulo: 'Cadastrar um Novo Imóvel',
    descricao: 'Aprenda a adicionar imóveis ao sistema com fotos, preço, localização e detalhes completos.',
    categoria: 'Imóveis',
    dificuldade: 'Fácil' as const,
    cor: '#2563eb',
    imagens: [IMG.imovel],
    passos: [
      { texto: 'No menu lateral, clique em "Imóveis" → "Novo Imóvel".' },
      { texto: 'Preencha o título, tipo (Venda ou Aluguel) e categoria (Casa, Apartamento, etc.).' },
      { texto: 'Informe o preço, área em m², quartos, banheiros e vagas de garagem.' },
      { texto: 'Preencha o bairro e cidade (ex: Meireles, Fortaleza).' },
      { texto: 'Adicione uma descrição detalhada do imóvel.' },
      { texto: 'Faça upload da foto de capa e da galeria de imagens.' },
      { texto: 'Marque como "Destaque" se quiser que apareça na home.' },
      { texto: 'Clique em "Salvar Imóvel" para publicar.' },
    ],
    link: '/dashboard/imoveis/novo',
    linkLabel: 'Cadastrar Imóvel',
  },
  {
    aba: 'imoveis',
    titulo: 'Editar ou Arquivar um Imóvel',
    descricao: 'Como atualizar informações, alterar status (vendido, alugado) ou remover um imóvel.',
    categoria: 'Imóveis',
    dificuldade: 'Fácil' as const,
    cor: '#2563eb',
    imagens: [IMG.imovel],
    passos: [
      { texto: 'Vá em "Imóveis" no menu lateral.' },
      { texto: 'Localize o imóvel na lista e clique em "Editar".' },
      { texto: 'Altere os campos desejados (preço, fotos, descrição, etc.).' },
      { texto: 'Para marcar como vendido, mude o campo "Status" para "Vendido".' },
      { texto: 'Clique em "Salvar" para aplicar as alterações.' },
      { texto: 'Para excluir, clique no ícone de lixeira na lista de imóveis.' },
    ],
    link: '/dashboard/imoveis',
    linkLabel: 'Ver Imóveis',
  },

  // ── Leads ──
  {
    aba: 'leads',
    titulo: 'Gerenciar Leads e Contatos',
    descricao: 'Veja quem entrou em contato, filtre por status e acompanhe cada negociação.',
    categoria: 'Leads',
    dificuldade: 'Fácil' as const,
    cor: '#9333ea',
    imagens: [IMG.leads],
    passos: [
      { texto: 'Clique em "Leads" no menu lateral para ver todos os contatos.' },
      { texto: 'Use o filtro "Status" para encontrar leads novos, em atendimento ou convertidos.' },
      { texto: 'Clique em um lead para ver detalhes: nome, WhatsApp, imóvel de interesse.' },
      { texto: 'Atualize o status do lead conforme o andamento da negociação.' },
      { texto: 'Use o WhatsApp diretamente pelo botão de contato no lead.' },
    ],
    link: '/dashboard/leads',
    linkLabel: 'Ver Leads',
  },

  // ── Personalizar ──
  {
    aba: 'personalizar',
    titulo: 'Alterar o Banner da Home',
    descricao: 'Troque a imagem, título e subtítulo do banner principal que os visitantes veem ao entrar no site.',
    categoria: 'Personalizar',
    dificuldade: 'Fácil' as const,
    cor: '#0891b2',
    imagens: [IMG.banner],
    passos: [
      { texto: 'No menu lateral, clique em "Banner / Hero".' },
      { texto: 'Edite o título principal (ex: "Encontre o imóvel dos seus sonhos").' },
      { texto: 'Edite o subtítulo e os textos dos botões de ação.' },
      { texto: 'Para trocar a imagem de fundo, clique na área de upload.' },
      { texto: 'Selecione uma foto do seu computador (JPG, PNG ou WebP).' },
      { texto: 'Clique em "Salvar Banner" para aplicar as mudanças.' },
    ],
    link: '/dashboard/banner',
    linkLabel: 'Editar Banner',
  },

  // ── Configurações ──
  {
    aba: 'configuracoes',
    titulo: 'Configurar Dados da Empresa',
    descricao: 'Atualize nome, CRECI, WhatsApp, e-mail, redes sociais, logo e horários de atendimento.',
    categoria: 'Configurações',
    dificuldade: 'Fácil' as const,
    cor: '#ea580c',
    imagens: [IMG.config],
    passos: [
      { texto: 'Acesse "Configurações" no menu lateral.' },
      { texto: 'Preencha o nome da empresa, CRECI e informações de contato.' },
      { texto: 'Adicione o número de WhatsApp — será usado pelo botão de contato do site.' },
      { texto: 'Informe os links do Instagram e Facebook da imobiliária.' },
      { texto: 'Faça upload do logo da empresa (aparece no topo do site e sidebar).' },
      { texto: 'Salve as alterações — o site será atualizado imediatamente.' },
    ],
    link: '/dashboard/configuracoes',
    linkLabel: 'Abrir Configurações',
  },
  {
    aba: 'configuracoes',
    titulo: 'Personalizar Cores do Site',
    descricao: 'Mude a cor principal do site para a identidade visual da sua imobiliária.',
    categoria: 'Configurações',
    dificuldade: 'Médio' as const,
    cor: '#ea580c',
    imagens: [IMG.config],
    passos: [
      { texto: 'Vá em "Configurações" no menu lateral.' },
      { texto: 'Localize o campo "Cor Primária" na seção de personalização.' },
      { texto: 'Clique no seletor de cor e escolha a cor da sua marca.' },
      { texto: 'A cor será aplicada em botões, destaques e links do site.' },
      { texto: 'Clique em "Salvar" para aplicar as mudanças em todo o site.' },
    ],
    link: '/dashboard/configuracoes',
    linkLabel: 'Abrir Configurações',
  },
] as const;

const abas = [
  { id: 'todos',            label: '🗂️ Todos',           count: tutoriais.length },
  { id: 'primeiros-passos', label: '🚀 Primeiros Passos', count: tutoriais.filter(t => t.aba === 'primeiros-passos').length },
  { id: 'imoveis',          label: '🏠 Imóveis',          count: tutoriais.filter(t => t.aba === 'imoveis').length },
  { id: 'leads',            label: '👥 Leads',            count: tutoriais.filter(t => t.aba === 'leads').length },
  { id: 'personalizar',     label: '🎨 Personalizar',     count: tutoriais.filter(t => t.aba === 'personalizar').length },
  { id: 'configuracoes',    label: '⚙️ Configurações',    count: tutoriais.filter(t => t.aba === 'configuracoes').length },
];
---

<AdminLayout title="Ajuda" breadcrumb="Dashboard / Ajuda">

  <!-- Hero da Ajuda -->
  <div class="help-hero">
    <div class="help-hero-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
    </div>
    <div>
      <h1 class="help-title">Central de Ajuda</h1>
      <p class="help-sub">Tutoriais passo a passo para usar todos os recursos do sistema com facilidade.</p>
    </div>
    <div class="help-search-wrap">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" id="help-search" placeholder="Buscar tutorial..." class="help-search" autocomplete="off" />
    </div>
  </div>

  <!-- Abas de Categoria -->
  <div class="help-tabs">
    {abas.map(aba => (
      <button
        class={`help-tab ${aba.id === 'todos' ? 'active' : ''}`}
        data-aba={aba.id}
        id={`tab-${aba.id}`}
      >
        {aba.label}
        <span class="help-tab-count">{aba.count}</span>
      </button>
    ))}
  </div>

  <!-- Grid de Tutoriais -->
  <div class="help-grid" id="help-grid">
    {tutoriais.map(t => (
      <div class="help-card-wrap" data-aba={t.aba} data-titulo={t.titulo.toLowerCase()}>
        <TutorialCard
          titulo={t.titulo}
          descricao={t.descricao}
          categoria={t.categoria}
          dificuldade={t.dificuldade}
          passos={[...t.passos]}
          imagens={[...t.imagens]}
          link={t.link}
          linkLabel={t.linkLabel}
          cor={t.cor}
        />
      </div>
    ))}
  </div>

  <!-- Estado vazio (busca sem resultado) -->
  <div id="help-empty" style="display:none;text-align:center;padding:4rem 2rem;color:var(--muted);">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:1rem;opacity:0.3;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <p style="font-size:1rem;font-weight:600;">Nenhum tutorial encontrado</p>
    <p style="font-size:0.85rem;margin-top:0.5rem;">Tente buscar por outro termo.</p>
  </div>

  <!-- Rodapé de ajuda -->
  <div class="help-footer">
    <div class="help-footer-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </div>
    <div>
      <strong>Ainda com dúvidas?</strong>
      <span> Entre em contato com o suporte via WhatsApp.</span>
    </div>
    <a href="https://wa.me/5585999998888" target="_blank" class="btn btn-sm" style="background:#25d366;color:white;border-color:#25d366;margin-left:auto;flex-shrink:0;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.999 0C5.373 0 0 5.373 0 12c0 2.117.554 4.099 1.523 5.824L0 24l6.335-1.5A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 11.999 0zm.001 21.818a9.818 9.818 0 0 1-5.012-1.373l-.36-.214-3.752.888.908-3.656-.234-.374A9.818 9.818 0 1 1 12 21.818z"/></svg>
      Falar no WhatsApp
    </a>
  </div>

  <!-- Lightbox Modal -->
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Imagem ampliada">
    <div id="lightbox-backdrop"></div>
    <div id="lightbox-box">
      <button id="lightbox-close" aria-label="Fechar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <img id="lightbox-img" src="" alt="Imagem ampliada" />
      <p id="lightbox-hint">Pressione Esc ou clique fora para fechar</p>
    </div>
  </div>

</AdminLayout>

<style>
  /* Hero */
  .help-hero {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
    border-radius: 16px;
    padding: 1.75rem 2rem;
    margin-bottom: 1.75rem;
    color: white;
    flex-wrap: wrap;
  }
  .help-hero-icon {
    width: 56px; height: 56px; border-radius: 14px;
    background: rgba(255,255,255,0.15); display: flex;
    align-items: center; justify-content: center; flex-shrink: 0;
  }
  .help-title { font-size: 1.35rem; font-weight: 800; margin: 0 0 0.2rem; }
  .help-sub { font-size: 0.875rem; opacity: 0.8; margin: 0; }
  .help-search-wrap {
    display: flex; align-items: center; gap: 0.6rem;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px; padding: 0.6rem 1rem; margin-left: auto;
    min-width: 240px;
  }
  .help-search-wrap svg { opacity: 0.6; flex-shrink: 0; }
  .help-search {
    background: none; border: none; outline: none; color: white;
    font-size: 0.875rem; width: 100%;
  }
  .help-search::placeholder { color: rgba(255,255,255,0.5); }

  /* Abas */
  .help-tabs {
    display: flex; gap: 0.5rem; flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .help-tab {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.5rem 1rem; border-radius: 10px; font-size: 0.82rem;
    font-weight: 600; background: var(--card-bg, #fff);
    border: 1.5px solid var(--border, #e5e7eb);
    color: var(--muted, #6b7280); cursor: pointer;
    transition: all 0.15s;
  }
  .help-tab:hover { border-color: #2563eb; color: #2563eb; }
  .help-tab.active { background: #2563eb; color: white; border-color: #2563eb; }
  .help-tab-count {
    background: rgba(0,0,0,0.1); border-radius: 99px;
    padding: 0.05rem 0.45rem; font-size: 0.7rem; font-weight: 800;
  }
  .help-tab.active .help-tab-count { background: rgba(255,255,255,0.25); }

  /* Grid */
  .help-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.25rem;
  }

  /* Footer */
  .help-footer {
    display: flex; align-items: center; gap: 1rem;
    background: var(--card-bg, #fff); border: 1px solid var(--border, #e5e7eb);
    border-radius: 12px; padding: 1.1rem 1.5rem; margin-top: 2rem;
    font-size: 0.875rem; color: var(--text, #374151); flex-wrap: wrap;
  }
  .help-footer-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: #dcfce7; color: #16a34a;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .help-hero { flex-direction: column; align-items: flex-start; }
    .help-search-wrap { width: 100%; margin-left: 0; }
    .help-grid { grid-template-columns: 1fr; }
  }

  /* ── Lightbox ── */
  #lightbox {
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    align-items: center; justify-content: center;
  }
  #lightbox.open { display: flex; }
  #lightbox-backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.88);
    backdrop-filter: blur(6px);
    animation: lbFadeIn 0.2s ease;
  }
  #lightbox-box {
    position: relative; z-index: 1;
    max-width: min(90vw, 1200px);
    max-height: 90vh;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
    animation: lbZoomIn 0.22s cubic-bezier(0.34,1.56,0.64,1);
  }
  #lightbox-img {
    display: block;
    max-width: 100%; max-height: 85vh;
    object-fit: contain;
    border-radius: 16px;
  }
  #lightbox-close {
    position: absolute; top: 0.75rem; right: 0.75rem;
    width: 36px; height: 36px;
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%; color: white; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.18s, transform 0.18s; z-index: 2;
  }
  #lightbox-close:hover { background: rgba(220,38,38,0.8); transform: scale(1.1); }
  #lightbox-hint {
    text-align: center; color: rgba(255,255,255,0.45);
    font-size: 0.72rem; margin-top: 0.75rem;
    position: absolute; bottom: -2rem; left: 0; right: 0;
  }
  @keyframes lbFadeIn  { from { opacity:0 } to { opacity:1 } }
  @keyframes lbZoomIn  { from { opacity:0; transform:scale(0.88) } to { opacity:1; transform:scale(1) } }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.help-tab');
  const cards = document.querySelectorAll<HTMLElement>('.help-card-wrap');
  const grid = document.getElementById('help-grid')!;
  const empty = document.getElementById('help-empty')!;
  const search = document.getElementById('help-search') as HTMLInputElement;

  let abaAtiva = 'todos';
  let termoBusca = '';

  function filtrar() {
    let visiveis = 0;
    cards.forEach(card => {
      const aba = card.dataset.aba!;
      const titulo = card.dataset.titulo!;
      const matchAba = abaAtiva === 'todos' || aba === abaAtiva;
      const matchBusca = !termoBusca || titulo.includes(termoBusca.toLowerCase());
      const mostrar = matchAba && matchBusca;
      card.style.display = mostrar ? '' : 'none';
      if (mostrar) visiveis++;
    });
    empty.style.display = visiveis === 0 ? 'block' : 'none';
    grid.style.display = visiveis === 0 ? 'none' : '';
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      abaAtiva = tab.dataset.aba!;
      filtrar();
    });
  });

  search.addEventListener('input', () => {
    termoBusca = search.value.trim();
    if (termoBusca && abaAtiva !== 'todos') {
      tabs.forEach(t => t.classList.remove('active'));
      document.querySelector('[data-aba="todos"]')?.classList.add('active');
      abaAtiva = 'todos';
    }
    filtrar();
  });

  // ── Lightbox ──
  const lb        = document.getElementById('lightbox')!;
  const lbImg     = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbClose   = document.getElementById('lightbox-close')!;
  const lbBackdrop = document.getElementById('lightbox-backdrop')!;

  function openLightbox(src: string) {
    lbImg.src = src;
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(() => { lbImg.src = ''; }, 300);
  }

  document.addEventListener('lightbox:open', (e: Event) => {
    const src = (e as CustomEvent).detail?.src;
    if (src) openLightbox(src);
  });

  lbClose.addEventListener('click', closeLightbox);
  lbBackdrop.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
