---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAuthFromCookie } from '../../../lib/auth';
import { db } from '../../../lib/db';
import { leads, imoveis } from '../../../lib/schema';
import { eq, desc, inArray } from 'drizzle-orm';

const auth = getAuthFromCookie(Astro.request);
if (!auth) return Astro.redirect('/auth/login');

// Processar ações POST
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const acao = String(form.get('acao') ?? '');
  const id   = String(form.get('id') ?? '');

  if (acao === 'contactado') {
    await db.update(leads).set({ status: 'em_atendimento' }).where(eq(leads.id, id));
  }
  if (acao === 'excluir') {
    await db.delete(leads).where(eq(leads.id, id));
  }
  if (acao === 'bulk_excluir') {
    const ids = String(form.get('bulk_ids') ?? '').split(',').filter(Boolean);
    if (ids.length > 0) await db.delete(leads).where(inArray(leads.id, ids));
  }
  if (acao === 'bulk_atendimento') {
    const ids = String(form.get('bulk_ids') ?? '').split(',').filter(Boolean);
    if (ids.length > 0) await db.update(leads).set({ status: 'em_atendimento' }).where(inArray(leads.id, ids));
  }
  return Astro.redirect('/dashboard/leads');
}

const filtroStatus = Astro.url.searchParams.get('status') ?? '';
const filtroOrigem = Astro.url.searchParams.get('origem') ?? '';

const leadsData = await db.select().from(leads)
  .orderBy(desc(leads.created_at));

let exibir = leadsData;
if (filtroStatus) exibir = exibir.filter(l => l.status === filtroStatus);
if (filtroOrigem) exibir = exibir.filter(l => l.origem === filtroOrigem);

function fmtData(s: any) {
  return new Date(s).toLocaleString('pt-BR', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

const origemLabel: Record<string, string> = {
  'contato':  'Formulário Contato',
  'imovel':   'Página Imóvel',
  'whatsapp': 'WhatsApp',
  'financie': 'Financiamento',
};
const origemBadge: Record<string, string> = {
  'contato':  'badge-info',
  'imovel':   'badge-warning',
  'whatsapp': 'badge-success',
  'financie': 'badge-gray',
};

// Cards de origem com totais
const origens = ['contato', 'imovel', 'whatsapp', 'financie'];
const stats = origens.map(o => ({
  origem: o,
  label: origemLabel[o] ?? o,
  badge: origemBadge[o] ?? 'badge-gray',
  total: leadsData.filter(l => l.origem === o).length,
  novos: leadsData.filter(l => l.origem === o && l.status === 'novo').length,
})).filter(s => s.total > 0);
---

<AdminLayout title="Leads" breadcrumb="Dashboard / Leads">

  <!-- Page header -->
  <div class="page-header">
    <div class="page-header-left">
      <h1>Gerenciar Leads</h1>
      <p>{leadsData.length} lead(s) recebido(s) no total</p>
    </div>
    <div class="page-header-right">
      <button class="btn btn-outline-dark" onclick="exportarCSV()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.35rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Exportar CSV
      </button>
    </div>
  </div>

  <!-- Cards de origem -->
  {stats.length > 0 && (
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.875rem;margin-bottom:1.5rem;">
      {stats.map(s => (
        <a
          href={`/dashboard/leads?origem=${s.origem}`}
          class="card"
          style={`padding:1rem;cursor:pointer;text-decoration:none;transition:box-shadow 0.18s;border:2px solid ${filtroOrigem === s.origem ? 'var(--primary)' : 'var(--border)'};`}
          onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)'"
          onmouseout="this.style.boxShadow=''"
        >
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <span class={`badge ${s.badge}`} style="font-size:0.7rem;">{s.label}</span>
            {s.novos > 0 && (
              <span style="background:#ef4444;color:white;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;">{s.novos}</span>
            )}
          </div>
          <div style="font-size:1.5rem;font-weight:800;color:var(--text);margin-top:0.5rem;">{s.total}</div>
          <div style="font-size:0.75rem;color:var(--muted);">leads totais</div>
        </a>
      ))}
    </div>
  )}

  <!-- Filtros de Status + Origem -->
  <div style="display:flex;gap:0.5rem;margin-bottom:1.25rem;flex-wrap:wrap;align-items:center;">
    <span style="font-size:0.75rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;">Status:</span>
    {(['', 'novo', 'em_atendimento', 'convertido'] as const).map(s => (
      <a
        href={`/dashboard/leads?${s ? `status=${s}` : ''}${filtroOrigem ? `&origem=${filtroOrigem}` : ''}`}
        class={`btn btn-sm ${filtroStatus === s && !filtroOrigem ? 'btn-primary' : 'btn-outline'}`}
      >
        {s === '' ? 'Todos' : s === 'em_atendimento' ? 'Em atendimento' : s.charAt(0).toUpperCase() + s.slice(1)} 
        ({s ? leadsData.filter(l => l.status === s && (!filtroOrigem || l.origem === filtroOrigem)).length : leadsData.filter(l => !filtroOrigem || l.origem === filtroOrigem).length})
      </a>
    ))}

    {filtroOrigem && (
      <a href="/dashboard/leads" class="btn btn-sm btn-outline" style="margin-left:auto;color:var(--danger);border-color:var(--danger);">
        ✕ Limpar filtros
      </a>
    )}
  </div>

  <!-- Tabela -->
  <div class="card" style="position:relative;">
    
    <!-- Bulk Action Bar (escondida por padrão) -->
    <div id="bulk-bar" style="display:none;position:absolute;top:0;left:0;right:0;background:#f8fafc;padding:0.75rem 1.5rem;border-bottom:1px solid var(--border);z-index:10;align-items:center;justify-content:space-between;border-radius:10px 10px 0 0;">
      <div style="font-size:0.875rem;font-weight:600;color:var(--primary);">
        <span id="bulk-count">0</span> lead(s) selecionado(s)
      </div>
      <div style="display:flex;gap:0.75rem;">
        <button class="btn btn-sm btn-success" onclick="executarBulk('bulk_atendimento')">✓ Marcar como Em Atendimento</button>
        <button class="btn btn-sm" style="background:#fee2e2;color:#991b1b;border:none;" onclick="executarBulk('bulk_excluir')">✕ Excluir Selecionados</button>
      </div>
    </div>
    <form method="POST" id="bulk-form" style="display:none;">
      <input type="hidden" name="acao" id="bulk-acao" value="" />
      <input type="hidden" name="bulk_ids" id="bulk-ids" value="" />
    </form>

    <div class="table-wrap">
      {exibir.length === 0 ? (
        <div style="padding:3rem;text-align:center;color:var(--muted);">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 1rem;opacity:0.3;display:block;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          Nenhum lead encontrado com os filtros aplicados.
        </div>
      ) : (
        <table>
          <thead>
            <tr>
              <th style="width:40px;"><input type="checkbox" id="check-all" onchange="toggleAll(this)" /></th>
              <th>Origem</th>
              <th>Nome</th>
              <th>WhatsApp</th>
              <th>Interesse</th>
              <th>Status</th>
              <th>Data</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            {exibir.map(l => (
              <tr style="cursor:pointer;" onclick={`abrirDetalhe('${l.id}')`}>
                <td onclick="event.stopPropagation()"><input type="checkbox" class="lead-check" value={l.id} onchange="atualizarBulkBar()" /></td>
                <!-- Origem -->
                <td onclick="event.stopPropagation()">
                  <span class={`badge ${origemBadge[l.origem ?? ''] ?? 'badge-gray'}`} style="white-space:nowrap;font-size:0.7rem;">
                    {origemLabel[l.origem ?? ''] ?? l.origem ?? '—'}
                  </span>
                </td>

                <!-- Nome + email -->
                <td>
                  <div style="font-weight:600;">{l.nome}</div>
                  {l.email && <div style="color:var(--muted);font-size:0.75rem;">{l.email}</div>}
                </td>

                <!-- WhatsApp -->
                <td onclick="event.stopPropagation()">
                  {l.whatsapp ? (
                    <a href={`https://wa.me/55${l.whatsapp.replace(/\D/g,'')}`} target="_blank"
                      style="color:var(--primary);font-weight:500;">
                      {l.whatsapp}
                    </a>
                  ) : <span style="color:var(--muted);">—</span>}
                </td>

                <!-- Interesse -->
                <td style="color:var(--muted);font-size:0.85rem;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  {l.mensagem?.slice(0, 50) ?? '—'}
                </td>

                <!-- Status -->
                <td>
                  <span class={`badge ${l.status === 'novo' ? 'badge-info' : l.status === 'convertido' ? 'badge-success' : 'badge-warning'}`}>
                    {l.status}
                  </span>
                </td>

                <!-- Data -->
                <td style="color:var(--muted);font-size:0.78rem;white-space:nowrap;">
                  {fmtData(l.created_at)}
                </td>

                <!-- Ações -->
                <td onclick="event.stopPropagation()">
                  <div class="td-actions">
                    {l.status === 'novo' && (
                      <form method="POST" style="display:inline;">
                        <input type="hidden" name="acao" value="contactado" />
                        <input type="hidden" name="id" value={l.id} />
                        <button class="btn btn-success btn-sm" title="Marcar como em atendimento">✓</button>
                      </form>
                    )}
                    <form method="POST" style="display:inline;">
                      <input type="hidden" name="acao" value="excluir" />
                      <input type="hidden" name="id" value={l.id} />
                      <button class="btn btn-sm" style="background:#fee2e2;color:#991b1b;border:none;"
                        onclick="return confirm('Excluir este lead?')">✕</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AdminLayout>

<!-- Modal de Detalhes do Lead -->
<div id="modal-detalhe" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:white;border-radius:16px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 60px rgba(0,0,0,0.3);">

    <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);">
      <div>
        <div id="det-title" style="font-size:1.1rem;font-weight:700;"></div>
        <div id="det-origem" style="margin-top:0.25rem;"></div>
      </div>
      <button onclick="fecharDetalhe()" style="background:none;border:none;cursor:pointer;color:var(--muted);padding:0.25rem;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div id="det-body" style="padding:1.5rem;display:flex;flex-direction:column;gap:1.25rem;"></div>
  </div>
</div>

<script define:vars={{ leadsData: exibir, origemLabelMap: origemLabel, origemBadgeMap: origemBadge }}>
  function abrirDetalhe(id) {
    const l = leadsData.find(x => x.id === id);
    if (!l) return;

    document.getElementById('det-title').textContent = l.nome;
    document.getElementById('det-origem').innerHTML =
      `<span class="badge ${origemBadgeMap[l.origem] ?? 'badge-gray'}" style="font-size:0.72rem;">${origemLabelMap[l.origem] ?? l.origem ?? '—'}</span>`;

    let html = `
      <div>
        <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#64748b;margin-bottom:0.75rem;">Contato</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.625rem;">
          ${row('📱 WhatsApp', l.whatsapp ? `<a href="https://wa.me/55${l.whatsapp.replace(/\D/g,'')}" target="_blank" style="color:#0d6efd;font-weight:600;">${l.whatsapp}</a>` : '—')}
          ${row('📧 E-mail', l.email ?? '—')}
        </div>
      </div>`;

    if (l.mensagem) {
      html += `
      <hr style="border:none;border-top:1px solid #e2e8f0;">
      <div>
        <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#64748b;margin-bottom:0.75rem;">Mensagem</div>
        <div style="font-size:0.85rem;color:#1e293b;padding:0.75rem;background:#f8fafc;border-radius:8px;line-height:1.6;">${l.mensagem}</div>
      </div>`;
    }

    document.getElementById('det-body').innerHTML = html;
    document.getElementById('modal-detalhe').style.display = 'flex';
  }

  function fecharDetalhe() {
    document.getElementById('modal-detalhe').style.display = 'none';
  }

  function toggleAll(el) {
    const checks = document.querySelectorAll('.lead-check');
    checks.forEach(c => c.checked = el.checked);
    atualizarBulkBar();
  }

  function atualizarBulkBar() {
    const checks = document.querySelectorAll('.lead-check:checked');
    const bulkBar = document.getElementById('bulk-bar');
    const bulkCount = document.getElementById('bulk-count');
    
    if (checks.length > 0) {
      bulkBar.style.display = 'flex';
      bulkCount.textContent = checks.length;
    } else {
      bulkBar.style.display = 'none';
    }
    
    // Atualiza check-all se todos estiverem marcados
    const allChecks = document.querySelectorAll('.lead-check');
    const checkAll = document.getElementById('check-all');
    if (checkAll && allChecks.length > 0) {
      checkAll.checked = checks.length === allChecks.length;
    }
  }

  function executarBulk(acao) {
    const checks = document.querySelectorAll('.lead-check:checked');
    if (checks.length === 0) return;
    
    if (acao === 'bulk_excluir' && !confirm('Tem certeza que deseja EXCLUIR os ' + checks.length + ' leads selecionados?')) return;
    
    const ids = Array.from(checks).map(c => c.value).join(',');
    document.getElementById('bulk-acao').value = acao;
    document.getElementById('bulk-ids').value = ids;
    document.getElementById('bulk-form').submit();
  }

  function row(label, value) {
    return `<div style="font-size:0.82rem;">
      <div style="color:#64748b;font-size:0.72rem;margin-bottom:0.125rem;">${label}</div>
      <div style="font-weight:600;color:#1e293b;">${value}</div>
    </div>`;
  }

  function exportarCSV() {
    if (leadsData.length === 0) return alert('Nenhum lead para exportar.');
    const headers = ['Data', 'Nome', 'Email', 'WhatsApp', 'Origem', 'Status', 'Mensagem'];
    const linhas = leadsData.map(l => [
      new Date(l.created_at).toLocaleString('pt-BR'),
      l.nome || '',
      l.email || '',
      l.whatsapp || '',
      origemLabelMap[l.origem] || l.origem || '',
      l.status || '',
      (l.mensagem || '').replace(/\\n/g, ' ')
    ]);
    const csvContent = [
      headers.join(','),
      ...linhas.map(row => row.map(v => '"' + String(v).replace(/"/g, '""') + '"').join(','))
    ].join('\\n');

    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.setAttribute('download', `leads_${new Date().getTime()}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  window.exportarCSV = exportarCSV;
  window.abrirDetalhe = abrirDetalhe;
  window.fecharDetalhe = fecharDetalhe;

  document.getElementById('modal-detalhe').addEventListener('click', function(e) {
    if (e.target === this) fecharDetalhe();
  });
</script>
